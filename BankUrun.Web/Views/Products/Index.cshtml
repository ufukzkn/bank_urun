@using BankUrun.Web.Models
@model BankUrun.Web.ViewModels.ProductIndexViewModel

@{
    ViewData["Title"] = "";
    var activeMainProducts = Model.MainProducts.Where(product => product.IsActive).ToList();
    var mainCount = Model.MainProducts.Count;
    var subCount = Model.Rows.Count(row => row.SubProductId.HasValue);
}

<section class="workspace-grid">
    <div class="surface-panel create-panel">
        <div class="panel-heading">
            <div>
                <h1>Kayıt oluştur</h1>
                <p>Ana ürün veya seçili ana ürün altında alt ürün ekle.</p>
            </div>
        </div>

        <form asp-action="CreateProduct" method="post" class="stack-form">
            @Html.AntiForgeryToken()
            <div class="form-row">
                <label>
                    <span>Tip</span>
                    <select class="form-select" name="Type" id="productType">
                        <option value="@ProductType.Main">Ana ürün</option>
                        <option value="@ProductType.Sub">Alt ürün</option>
                    </select>
                </label>
                <label>
                    <span>Kod</span>
                    <select class="form-select" name="CodeMode" id="codeMode">
                        <option value="Auto">Otomatik üret</option>
                        <option value="Manual">Manuel gir</option>
                    </select>
                </label>
            </div>

            <label id="manualCodeWrap" class="manual-code-wrap">
                <span>Manuel kod</span>
                <input class="form-control code-input" type="text" name="ManualCode" id="manualCode" maxlength="2" autocomplete="off" />
                <small id="codeSuggestion" class="form-text"></small>
            </label>

            <label>
                <span>Ad</span>
                <input class="form-control" type="text" name="Name" maxlength="180" required />
            </label>

            <div class="form-row" id="periodFields">
                <label>
                    <span>Yıl</span>
                    <input class="form-control" type="number" name="Year" min="2000" max="2100" value="2026" required />
                </label>
                <label>
                    <span>Dönem</span>
                    <input class="form-control" type="number" name="Term" min="1" max="12" value="1" required />
                </label>
            </div>

            <label id="createMainProductWrap" class="sub-product-field">
                <span>Bağlı ana ürün</span>
                <input class="form-control combobox-input" type="search" id="createMainProductSearch" list="mainProductOptions" placeholder="Kod, ad veya yıl/dönem ara" autocomplete="off" />
                <input type="hidden" name="MainProductId" id="createMainProductId" />
                <datalist id="mainProductOptions">
                    @foreach (var product in activeMainProducts)
                    {
                        <option value="@product.Label" data-id="@product.Id"></option>
                    }
                </datalist>
            </label>

            <button class="btn btn-primary" type="submit">Kaydı oluştur</button>
        </form>

        @if (TempData["Success"] is string success)
        {
            <div class="alert alert-success action-alert" role="alert">@success</div>
        }

        @if (TempData["Error"] is string error)
        {
            <div class="alert alert-danger action-alert" role="alert">@error</div>
        }
    </div>

    <aside class="surface-panel summary-panel">
        <div>
            <span class="summary-label">Ana ürün</span>
            <strong>@mainCount</strong>
        </div>
        <div>
            <span class="summary-label">Alt ürün</span>
            <strong>@subCount</strong>
        </div>
        <div>
            <span class="summary-label">Görünen</span>
            <strong id="visibleCount">@Model.Rows.Count</strong>
        </div>
    </aside>
</section>

<section class="surface-panel table-panel">
    <div class="table-toolbar" id="listFilterForm">
        <label class="toolbar-search">
            <span>Liste içinde ara</span>
            <input class="form-control list-filter" type="search" id="filterSearch" placeholder="Kod, ana ürün veya alt ürün adı" />
        </label>
        <label>
            <span>Yıl</span>
            <input class="form-control list-filter" type="number" id="filterYear" min="2000" max="2100" />
        </label>
        <label>
            <span>Dönem</span>
            <input class="form-control list-filter" type="number" id="filterTerm" min="1" max="12" />
        </label>
        <label>
            <span>Sayfa</span>
            <select class="form-select list-filter" id="pageSize">
                <option value="10">10</option>
                <option value="25">25</option>
                <option value="50">50</option>
            </select>
        </label>
        <label class="check-line">
            <input class="form-check-input list-filter" type="checkbox" id="includeInactive" />
            <span>Pasifler</span>
        </label>
        <label class="check-line">
            <input class="form-check-input list-filter" type="checkbox" id="showMainProducts" checked />
            <span>Ana kayıtlar</span>
        </label>
        <label class="check-line">
            <input class="form-check-input list-filter" type="checkbox" id="showSubProducts" checked />
            <span>Alt kayıtlar</span>
        </label>
    </div>

    <div class="table-responsive">
        <table class="table product-table">
            <thead>
                <tr>
                    <th>Yıl</th>
                    <th>Dönem</th>
                    <th>Ana Kod</th>
                    <th>Alt Kod</th>
                    <th>Alt Ürün Adı</th>
                    <th class="text-end">İşlem</th>
                </tr>
            </thead>
            <tbody id="productTableBody">
            @if (Model.Rows.Count == 0)
            {
                <tr class="empty-row">
                    <td colspan="6" class="empty-cell">Kayıt yok</td>
                </tr>
            }
            @for (var rowIndex = 0; rowIndex < Model.Rows.Count; rowIndex++)
            {
                var row = Model.Rows[rowIndex];
                var detailsId = $"row-actions-{row.MainProductId}-{row.SubProductId ?? 0}-{rowIndex}";
                var searchText = $"{row.Year} {row.Term} {row.MainProductCode} {row.MainProductName} {row.SubProductCode} {row.SubProductName}".ToUpperInvariant();
                <tr class="product-row"
                    data-year="@row.Year"
                    data-term="@row.Term"
                    data-has-sub="@(row.SubProductId.HasValue ? "true" : "false")"
                    data-active="@((row.MainProductActive && (!row.SubProductId.HasValue || row.SubProductActive == true)) ? "true" : "false")"
                    data-search="@searchText">
                    <td>@row.Year</td>
                    <td>@row.Term</td>
                    <td>
                        <strong>@row.MainProductCode</strong>
                        <small>@row.MainProductName</small>
                    </td>
                    <td>
                        @if (row.SubProductId.HasValue)
                        {
                            <strong>@row.SubProductCode</strong>
                        }
                        else
                        {
                            <span class="muted">-</span>
                        }
                    </td>
                    <td>
                        @if (row.SubProductId.HasValue)
                        {
                            <span>@row.SubProductName</span>
                        }
                        else
                        {
                            <span class="muted">Alt ürün yok</span>
                        }
                    </td>
                    <td class="text-end">
                        <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="collapse" data-bs-target="#@detailsId" aria-expanded="false" aria-controls="@detailsId">Düzenle</button>
                    </td>
                </tr>
                <tr class="actions-row" data-actions-for="@detailsId">
                    <td colspan="6">
                        <div class="collapse" id="@detailsId">
                            <div class="actions-panel">
                                <div class="status-line">
                                    <span class="status-pill @(row.MainProductActive ? "active" : "passive")">Ana @(row.MainProductActive ? "Aktif" : "Pasif")</span>
                                    @if (row.SubProductId.HasValue)
                                    {
                                        <span class="status-pill @(row.SubProductActive == true ? "active" : "passive")">Alt @(row.SubProductActive == true ? "Aktif" : "Pasif")</span>
                                    }
                                </div>
                                <div class="actions-cell">
                                    <span class="action-group-title">Ana ürün</span>
                                    <form asp-action="RenameProduct" method="post" class="inline-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="Type" value="@ProductType.Main" />
                                        <input type="hidden" name="ProductId" value="@row.MainProductId" />
                                        <input class="form-control form-control-sm" name="Name" value="@row.MainProductName" maxlength="180" />
                                        <button class="btn btn-sm btn-outline-primary" type="submit" data-confirm="Ana ürün adını değiştirmek istediğinize emin misiniz?">Adını değiştir</button>
                                    </form>
                                    <form asp-action="DeactivateProduct" method="post" class="button-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="Type" value="@ProductType.Main" />
                                        <input type="hidden" name="ProductId" value="@row.MainProductId" />
                                        <button class="btn btn-sm btn-outline-warning" type="submit" data-confirm="Ana ürünü ve alt ürünlerini pasifleştirmek istediğinize emin misiniz?">Pasifleştir</button>
                                    </form>
                                    <form asp-action="DeleteProduct" method="post" class="button-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="Type" value="@ProductType.Main" />
                                        <input type="hidden" name="ProductId" value="@row.MainProductId" />
                                        <button class="btn btn-sm btn-outline-danger" type="submit" data-confirm="Bu ana ürün ve alt ürünleri kalıcı silinecek. Emin misiniz?">Sil</button>
                                    </form>

                                    @if (row.SubProductId.HasValue)
                                    {
                                        <span class="action-group-title">Alt ürün</span>
                                        <form asp-action="RenameProduct" method="post" class="inline-form">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="Type" value="@ProductType.Sub" />
                                            <input type="hidden" name="ProductId" value="@row.SubProductId" />
                                            <input class="form-control form-control-sm" name="Name" value="@row.SubProductName" maxlength="180" />
                                            <button class="btn btn-sm btn-outline-primary" type="submit" data-confirm="Alt ürün adını değiştirmek istediğinize emin misiniz?">Adını değiştir</button>
                                        </form>
                                        <form asp-action="DeactivateProduct" method="post" class="button-form">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="Type" value="@ProductType.Sub" />
                                            <input type="hidden" name="ProductId" value="@row.SubProductId" />
                                            <button class="btn btn-sm btn-outline-warning" type="submit" data-confirm="Alt ürünü pasifleştirmek istediğinize emin misiniz?">Pasifleştir</button>
                                        </form>
                                        <form asp-action="DeleteProduct" method="post" class="button-form">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="Type" value="@ProductType.Sub" />
                                            <input type="hidden" name="ProductId" value="@row.SubProductId" />
                                            <button class="btn btn-sm btn-outline-danger" type="submit" data-confirm="Bu alt ürün kalıcı silinecek. Emin misiniz?">Sil</button>
                                        </form>
                                    }
                                </div>
                            </div>
                        </div>
                    </td>
                </tr>
            }
            <tr id="noClientRows" class="empty-row d-none">
                <td colspan="6" class="empty-cell">Filtreye uygun kayıt yok</td>
            </tr>
            </tbody>
        </table>
    </div>

    <div class="pagination-bar">
        <div class="pagination-summary" id="paginationSummary">Kayıtlar hazırlanıyor</div>
        <div class="pager-buttons">
            <button class="btn btn-sm btn-outline-secondary" type="button" id="prevPage">Önceki</button>
            <span id="pageIndicator">1 / 1</span>
            <button class="btn btn-sm btn-outline-secondary" type="button" id="nextPage">Sonraki</button>
        </div>
    </div>
</section>
