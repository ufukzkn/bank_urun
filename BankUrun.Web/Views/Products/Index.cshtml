@using BankUrun.Web.Models
@model BankUrun.Web.ViewModels.ProductIndexViewModel

@{
    ViewData["Title"] = "Ürünler";
    var activeMainProducts = Model.MainProducts.Where(product => product.IsActive).ToList();
}

<section class="page-title">
    <div>
        <h1>Ürünler</h1>
        <p>Ana ürün, alt ürün ve dönem bağlantıları.</p>
    </div>
</section>

<section class="workspace-grid compact-workspace-grid">
    <div class="surface-panel create-panel compact-create-panel">
        <div class="panel-heading">
            <div>
                <h1>Ürün oluştur</h1>
                <p>Ana ürün veya seçili ana ürün altında alt ürün ekle.</p>
            </div>
        </div>

        <form asp-action="CreateProduct" method="post" class="stack-form compact-stack-form">
            @Html.AntiForgeryToken()
            <div class="form-row">
                <label>
                    <span>Tip</span>
                    <select class="form-select" name="Type" id="productType">
                        <option value="@ProductType.Main">Ana ürün</option>
                        <option value="@ProductType.Sub">Alt ürün</option>
                    </select>
                </label>
                <label>
                    <span>Kod</span>
                    <select class="form-select" name="CodeMode" id="codeMode">
                        <option value="Auto">Otomatik üret</option>
                        <option value="Manual">Manuel gir</option>
                    </select>
                </label>
            </div>

            <label id="createMainProductWrap" class="sub-product-field">
                <span>Bağlı ana ürün</span>
                <div class="combo" id="mainProductCombo">
                    <input class="form-control combobox-input" type="search" id="createMainProductSearch" placeholder="Kod, ad veya yıl/dönem ara" autocomplete="off" />
                    <div class="combo-menu" id="mainProductOptions" role="listbox">
                        @foreach (var product in activeMainProducts)
                        {
                            <button class="combo-option" type="button" role="option" data-id="@product.Id" data-label="@product.Label">
                                <strong>@product.Code</strong>
                                <span>@product.Name</span>
                                <small>@product.Year/@product.Term</small>
                            </button>
                        }
                        <div class="combo-empty">Uygun ana ürün yok</div>
                    </div>
                </div>
                <input type="hidden" name="MainProductInstanceId" id="createMainProductId" />
            </label>

            <label id="manualCodeWrap" class="manual-code-wrap">
                <span>Manuel kod</span>
                <input class="form-control code-input" type="text" name="ManualCode" id="manualCode" maxlength="2" autocomplete="off" />
                <small id="codeSuggestion" class="form-text"></small>
            </label>

            <label>
                <span>Ad</span>
                <input class="form-control" type="text" name="Name" maxlength="180" required />
            </label>

            <div class="form-row" id="periodFields">
                <label>
                    <span>Yıl</span>
                    <input class="form-control" type="number" name="Year" min="2000" max="2100" value="2026" required />
                </label>
                <label>
                    <span>Dönem</span>
                    <input class="form-control" type="number" name="Term" min="1" max="12" value="1" required />
                </label>
            </div>

            <button class="btn btn-primary" type="submit">Ürünü oluştur</button>
        </form>

        @if (TempData["Success"] is string success)
        {
            <div class="alert alert-success action-alert" role="alert">@success</div>
        }

        @if (TempData["Error"] is string error)
        {
            <div class="alert alert-danger action-alert" role="alert">@error</div>
        }
    </div>
</section>

<section class="surface-panel table-panel compact-list-panel" data-list="products">
    <div class="table-toolbar compact-table-toolbar" id="listFilterForm">
        <label class="toolbar-search">
            <span>Liste içinde ara</span>
            <input class="form-control" type="search" data-list-filter="search" id="filterSearch" placeholder="Kod, ana ürün veya alt ürün adı" />
        </label>
        <label>
            <span>Yıl</span>
            <input class="form-control" type="number" data-list-filter="year" id="filterYear" min="2000" max="2100" />
        </label>
        <label>
            <span>Dönem</span>
            <input class="form-control" type="number" data-list-filter="term" id="filterTerm" min="1" max="12" />
        </label>
        <label>
            <span>Sayfa</span>
            <select class="form-select" data-list-page-size id="pageSize">
                <option value="10">10</option>
                <option value="25">25</option>
                <option value="50">50</option>
            </select>
        </label>
        <label class="check-line">
            <input class="form-check-input" type="checkbox" data-list-filter="includeInactive" id="includeInactive" />
            <span>Pasifler</span>
        </label>
        <label class="check-line">
            <input class="form-check-input" type="checkbox" data-list-filter="showMainProducts" id="showMainProducts" checked />
            <span>Ana ürünler</span>
        </label>
        <label class="check-line">
            <input class="form-check-input" type="checkbox" data-list-filter="showSubProducts" id="showSubProducts" checked />
            <span>Alt ürünler</span>
        </label>
    </div>

    <div class="table-responsive">
        <table class="table product-table">
            <thead>
                <tr>
                    <th><button class="sort-button" type="button" data-list-sort="year">Yıl <span></span></button></th>
                    <th><button class="sort-button" type="button" data-list-sort="term">Dönem <span></span></button></th>
                    <th><button class="sort-button" type="button" data-list-sort="mainCode">Ana Kod <span></span></button></th>
                    <th><button class="sort-button" type="button" data-list-sort="subCode">Alt Kod <span></span></button></th>
                    <th><button class="sort-button" type="button" data-list-sort="subName">Alt Ürün Adı <span></span></button></th>
                    <th class="text-end">İşlem</th>
                </tr>
            </thead>
            <tbody id="productTableBody">
            @if (Model.Rows.Count == 0)
            {
                <tr class="empty-row">
                    <td colspan="6" class="empty-cell">Ürün yok</td>
                </tr>
            }
            @for (var rowIndex = 0; rowIndex < Model.Rows.Count; rowIndex++)
            {
                var row = Model.Rows[rowIndex];
                var detailsId = $"row-actions-{row.MainProductInstanceId}-{row.SubProductInstanceId ?? 0}-{rowIndex}";
                var searchText = $"{row.Year} {row.Term} {row.MainProductCode} {row.MainProductName} {row.SubProductCode} {row.SubProductName}".ToUpperInvariant();
                <tr class="list-row product-row"
                    data-detail-id="@detailsId"
                    data-year="@row.Year"
                    data-term="@row.Term"
                    data-main-code="@row.MainProductCode"
                    data-sub-code="@(row.SubProductCode ?? "")"
                    data-sub-name="@(row.SubProductName ?? "")"
                    data-has-sub="@(row.SubProductId.HasValue ? "true" : "false")"
                    data-active="@((row.MainProductActive && (!row.SubProductId.HasValue || row.SubProductActive == true)) ? "true" : "false")"
                    data-search="@searchText">
                    <td>@row.Year</td>
                    <td>@row.Term</td>
                    <td>
                        <strong>@row.MainProductCode</strong>
                        <small>@row.MainProductName</small>
                    </td>
                    <td>
                        @if (row.SubProductId.HasValue)
                        {
                            <strong>@row.SubProductCode</strong>
                        }
                        else
                        {
                            <span class="muted">-</span>
                        }
                    </td>
                    <td>
                        @if (row.SubProductId.HasValue)
                        {
                            <span>@row.SubProductName</span>
                        }
                        else
                        {
                            <span class="muted">Alt ürün yok</span>
                        }
                    </td>
                    <td class="text-end">
                        <button class="btn btn-sm btn-outline-primary detail-button" type="button" data-bs-toggle="collapse" data-bs-target="#@detailsId" aria-expanded="false" aria-controls="@detailsId">Detay</button>
                    </td>
                </tr>
                <tr class="list-detail-row actions-row" data-detail-for="@detailsId">
                    <td colspan="6">
                        <div class="collapse" id="@detailsId">
                            <div class="actions-panel">
                                <div class="status-line">
                                    <span class="status-pill @(row.MainProductActive ? "active" : "passive")">Ana @(row.MainProductActive ? "Aktif" : "Pasif")</span>
                                    @if (row.SubProductId.HasValue)
                                    {
                                        <span class="status-pill @(row.SubProductActive == true ? "active" : "passive")">Alt @(row.SubProductActive == true ? "Aktif" : "Pasif")</span>
                                    }
                                </div>
                                <div class="actions-cell">
                                    <span class="action-group-title">Ana ürün</span>
                                    <form asp-action="RenameProduct" method="post" class="inline-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="Type" value="@ProductType.Main" />
                                        <input type="hidden" name="ProductId" value="@row.MainProductId" />
                                        <input class="form-control form-control-sm code-edit-input" name="Code" value="@row.MainProductCode" maxlength="2" />
                                        <input class="form-control form-control-sm" name="Name" value="@row.MainProductName" maxlength="180" />
                                        <button class="btn btn-sm btn-outline-primary" type="submit" data-confirm="Ana ürün bilgisini değiştirmek istediğinize emin misiniz?">Güncelle</button>
                                    </form>
                                    <form asp-action="DeactivateProduct" method="post" class="button-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="Type" value="@ProductType.Main" />
                                        <input type="hidden" name="ProductId" value="@row.MainProductId" />
                                        <button class="btn btn-sm btn-outline-warning" type="submit" data-confirm="Ana ürünü ve alt ürünlerini pasifleştirmek istediğinize emin misiniz?">Pasifleştir</button>
                                    </form>
                                    <form asp-action="DeleteProduct" method="post" class="button-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="Type" value="@ProductType.Main" />
                                        <input type="hidden" name="ProductId" value="@row.MainProductId" />
                                        <input type="hidden" name="MainProductInstanceId" value="@row.MainProductInstanceId" />
                                        <input type="hidden" name="DeleteScope" value="Single" class="delete-scope" />
                                        <button class="btn btn-sm btn-outline-danger" type="submit" data-action-type="delete" data-confirm="Bu ana ürünü silmek istediğinize emin misiniz?">Sil</button>
                                    </form>

                                    @if (row.SubProductId.HasValue)
                                    {
                                        <span class="action-group-title">Alt ürün</span>
                                        <form asp-action="RenameProduct" method="post" class="inline-form">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="Type" value="@ProductType.Sub" />
                                            <input type="hidden" name="ProductId" value="@row.SubProductId" />
                                            <input class="form-control form-control-sm code-edit-input" name="Code" value="@row.SubProductCode" maxlength="2" />
                                            <input class="form-control form-control-sm" name="Name" value="@row.SubProductName" maxlength="180" />
                                            <button class="btn btn-sm btn-outline-primary" type="submit" data-confirm="Bu alt ürün koduna sahip tüm satırlar güncellenecek. Emin misiniz?">Güncelle</button>
                                        </form>
                                        <form asp-action="DeactivateProduct" method="post" class="button-form">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="Type" value="@ProductType.Sub" />
                                            <input type="hidden" name="ProductId" value="@row.SubProductId" />
                                            <button class="btn btn-sm btn-outline-warning" type="submit" data-confirm="Alt ürünü pasifleştirmek istediğinize emin misiniz?">Pasifleştir</button>
                                        </form>
                                        <form asp-action="DeleteProduct" method="post" class="button-form">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="Type" value="@ProductType.Sub" />
                                            <input type="hidden" name="ProductId" value="@row.SubProductId" />
                                            <input type="hidden" name="SubProductInstanceId" value="@row.SubProductInstanceId" />
                                            <input type="hidden" name="DeleteScope" value="Single" class="delete-scope" />
                                            <button class="btn btn-sm btn-outline-danger" type="submit" data-action-type="delete" data-confirm="Bu alt ürünü silmek istediğinize emin misiniz?">Sil</button>
                                        </form>
                                    }
                                </div>
                            </div>
                        </div>
                    </td>
                </tr>
            }
            <tr id="noClientRows" class="empty-row d-none" data-list-empty>
                <td colspan="6" class="empty-cell">Filtreye uygun ürün yok</td>
            </tr>
            </tbody>
        </table>
    </div>

    <div class="pagination-bar">
        <div class="pagination-summary" id="paginationSummary" data-list-summary>Ürünler hazırlanıyor</div>
        <div class="pager-buttons">
            <button class="btn btn-sm btn-outline-secondary icon-btn" type="button" data-list-page="first" aria-label="İlk sayfa" title="İlk sayfa">«</button>
            <button class="btn btn-sm btn-outline-secondary icon-btn" type="button" data-list-page="previous" aria-label="Önceki sayfa" title="Önceki sayfa">‹</button>
            <span id="pageIndicator" data-list-page-indicator>1 / 1</span>
            <input class="form-control form-control-sm page-jump" type="number" id="pageJump" min="1" value="1" data-list-page-jump aria-label="Sayfa numarası" />
            <button class="btn btn-sm btn-outline-secondary" type="button" data-list-page="jump">Git</button>
            <button class="btn btn-sm btn-outline-secondary icon-btn" type="button" data-list-page="next" aria-label="Sonraki sayfa" title="Sonraki sayfa">›</button>
            <button class="btn btn-sm btn-outline-secondary icon-btn" type="button" data-list-page="last" aria-label="Son sayfa" title="Son sayfa">»</button>
        </div>
    </div>
</section>

<div class="action-toast-backdrop" id="actionToastBackdrop"></div>
<div class="toast-container action-toast-container">
    <div id="actionConfirmToast" class="toast action-confirm-toast" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="toast-header">
            <strong class="me-auto" id="toastTitle">İşlemi onayla</strong>
            <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Kapat"></button>
        </div>
        <div class="toast-body">
            <p id="toastMessage" class="toast-message">Bu işlemi yapmak istediğinize emin misiniz?</p>
            <div class="toast-actions" id="standardToastActions">
                <button class="btn btn-sm btn-outline-secondary" type="button" data-toast-cancel>Vazgeç</button>
                <button class="btn btn-sm btn-primary" type="button" data-toast-confirm>Onayla</button>
            </div>
            <div class="toast-actions d-none" id="deleteToastActions">
                <button class="btn btn-sm btn-outline-secondary" type="button" data-toast-cancel>Vazgeç</button>
                <button class="btn btn-sm btn-outline-danger" type="button" data-delete-scope="Single">Seçili instance'ı sil</button>
                <button class="btn btn-sm btn-danger" type="button" data-delete-scope="All">Tüm tablodan sil</button>
            </div>
        </div>
    </div>
</div>
