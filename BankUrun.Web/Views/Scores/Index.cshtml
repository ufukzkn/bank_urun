@model BankUrun.Web.ViewModels.ScoreIndexViewModel

@{
    ViewData["Title"] = "Puanlar";
    string Fmt(decimal value) => value.ToString("0.##");
    string Pct(decimal value) => $"% {value:0.##}";
    string Width(decimal value) => Math.Clamp(value, 0, 100).ToString("0.##").Replace(",", ".");
    string SuccessLevel(decimal value) => value >= 90 ? "good" : value >= 70 ? "watch" : "low";
    string SuccessText(decimal value) => value >= 90 ? "Güçlü" : value >= 70 ? "İzleme" : "Düşük";
    var groups = Model.Branches
        .GroupBy(branch => new { branch.GroupId, branch.GroupNo, branch.GroupName })
        .OrderBy(group => group.Key.GroupNo)
        .ToList();
}

<section class="page-title">
    <div>
        <h1>Şube performansı</h1>
        <p>Şube bazlı ürün puanı, hedef ve pay parametreleri.</p>
    </div>
</section>

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success action-alert page-alert" role="alert">@success</div>
}

@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger action-alert page-alert" role="alert">@error</div>
}

<section class="surface-panel create-panel score-create-panel">
    <div class="panel-heading">
        <div>
            <h2>Puan satırı oluştur</h2>
            <p>Şube ve alt ürün instance seçerek performans parametresi kaydedin.</p>
        </div>
    </div>
    <form asp-action="CreateScore" method="post" class="stack-form combo-required-form">
        @Html.AntiForgeryToken()
        <div class="form-row">
            <label>
                <span>Şube</span>
                <div class="combo generic-combo">
                    <input class="form-control combobox-input" type="search" placeholder="Şube kodu, adı veya grup ara" autocomplete="off" data-combo-input />
                    <div class="combo-menu wide-combo-menu" role="listbox">
                        @foreach (var branch in Model.Branches)
                        {
                            <button class="combo-option product-combo-option" type="button" role="option" data-combo-option data-id="@branch.Id" data-group-id="@branch.GroupId" data-label="@branch.Label">
                                <strong>@branch.BranchCode</strong>
                                <span>@branch.Name</span>
                                <small>@branch.GroupNo</small>
                            </button>
                        }
                        <div class="combo-empty">Uygun şube yok</div>
                    </div>
                    <input type="hidden" name="BranchId" data-combo-value data-combo-required="Şube seçmelisiniz." />
                </div>
            </label>
            <label>
                <span>Alt ürün instance</span>
                <div class="combo generic-combo">
                    <input class="form-control combobox-input" type="search" placeholder="Yıl, dönem, ana kod veya alt ürün ara" autocomplete="off" data-combo-input />
                    <div class="combo-menu wide-combo-menu" role="listbox">
                        @foreach (var product in Model.SubProductInstances)
                        {
                            <button class="combo-option product-combo-option" type="button" role="option" data-combo-option data-id="@product.Id" data-label="@product.Label">
                                <strong>@product.MainProductCode/@product.SubProductCode</strong>
                                <span>@product.SubProductName</span>
                                <small>@product.Year/@product.Term</small>
                            </button>
                        }
                        <div class="combo-empty">Uygun alt ürün yok</div>
                    </div>
                    <input type="hidden" name="SubProductInstanceId" data-combo-value data-combo-required="Alt ürün instance seçmelisiniz." />
                </div>
            </label>
        </div>
        <div class="form-row score-fields">
            <label>
                <span>Puan</span>
                <input class="form-control decimal-input" name="Score" inputmode="decimal" value="0" required />
            </label>
            <label>
                <span>Hedef</span>
                <input class="form-control decimal-input" name="TargetValue" inputmode="decimal" value="0" required />
            </label>
            <label>
                <span>HGO payı %</span>
                <input class="form-control decimal-input" name="HgoShare" inputmode="decimal" value="0" required />
            </label>
            <label>
                <span>Gelişim payı %</span>
                <input class="form-control decimal-input" name="DevelopmentShare" inputmode="decimal" value="0" required />
            </label>
            <label>
                <span>Büyüklük payı %</span>
                <input class="form-control decimal-input" name="SizeShare" inputmode="decimal" value="0" required />
            </label>
        </div>
        <button class="btn btn-primary" type="submit">Puan oluştur</button>
    </form>
</section>

<section class="score-summary-grid" id="scoreSummary">
    <div class="score-summary-card">
        <span>Toplam puan</span>
        <strong id="totalScore">@Fmt(Model.TotalScore)</strong>
    </div>
    <div class="score-summary-card">
        <span>Toplam hedef</span>
        <strong id="totalTarget">@Fmt(Model.TotalTarget)</strong>
    </div>
    <div class="score-summary-card">
        <span>Başarı</span>
        <strong id="totalSuccess">@Pct(Model.SuccessRate)</strong>
    </div>
</section>

<section class="surface-panel performance-panel">
    <div class="panel-heading">
        <div>
            <h2>Şube başarı sıralaması</h2>
            <p>Filtre sonucuna göre puan / hedef oranı.</p>
        </div>
    </div>
    <div class="branch-chart" id="branchChart">
        @if (Model.BranchSuccess.Count == 0)
        {
            <div class="empty-inline">Grafik için puan kaydı yok</div>
        }
        @foreach (var item in Model.BranchSuccess)
        {
            var width = Math.Min(100, item.SuccessRate);
            <div class="branch-chart-row"
                 data-branch-id="@item.BranchId"
                 data-search="@($"{item.BranchCode} {item.BranchName} {item.GroupNo}".ToUpperInvariant())"
                 data-score="@item.TotalScore"
                 data-target="@item.TotalTarget">
                <div class="branch-chart-label">
                    <strong>@item.BranchCode</strong>
                    <span>@item.BranchName</span>
                    <small>@item.GroupNo</small>
                </div>
                <div class="branch-chart-track">
                    <div class="branch-chart-fill" style="width:@Fmt(width).Replace(",", ".")%"></div>
                </div>
                <div class="branch-chart-value">@Pct(item.SuccessRate)</div>
            </div>
        }
        <div id="noBranchChartRows" class="empty-inline d-none">Filtreye uygun grafik verisi yok</div>
    </div>
</section>

<section class="surface-panel table-panel">
    <div class="table-toolbar score-toolbar">
        <label class="toolbar-search">
            <span>Puan listesinde ara</span>
            <input class="form-control score-filter" type="search" id="scoreSearch" placeholder="Grup, şube, ürün, kod veya dönem" />
        </label>
        <label>
            <span>Grup</span>
            <select class="form-select score-filter" id="scoreGroup">
                <option value="">Tümü</option>
                @foreach (var group in groups)
                {
                    <option value="@group.Key.GroupId">@group.Key.GroupNo - @group.Key.GroupName</option>
                }
            </select>
        </label>
        <label>
            <span>Yıl</span>
            <input class="form-control score-filter" type="number" id="scoreYear" min="2000" max="2100" />
        </label>
        <label>
            <span>Dönem</span>
            <input class="form-control score-filter" type="number" id="scoreTerm" min="1" max="12" />
        </label>
    </div>
    <div class="table-responsive">
        <table class="table product-table score-table">
            <thead>
                <tr>
                    <th><button class="sort-button score-sort-button" type="button" data-score-sort="year">Yıl <span></span></button></th>
                    <th><button class="sort-button score-sort-button" type="button" data-score-sort="term">Dönem <span></span></button></th>
                    <th><button class="sort-button score-sort-button" type="button" data-score-sort="group">Grup <span></span></button></th>
                    <th><button class="sort-button score-sort-button" type="button" data-score-sort="branch">Şube <span></span></button></th>
                    <th><button class="sort-button score-sort-button" type="button" data-score-sort="main">Ana ürün <span></span></button></th>
                    <th><button class="sort-button score-sort-button" type="button" data-score-sort="sub">Alt ürün <span></span></button></th>
                    <th class="text-end"><button class="sort-button score-sort-button justify-content-end" type="button" data-score-sort="score">Puan <span></span></button></th>
                    <th class="text-end"><button class="sort-button score-sort-button justify-content-end" type="button" data-score-sort="displayed">Görüntülenen <span></span></button></th>
                    <th class="text-end"><button class="sort-button score-sort-button justify-content-end" type="button" data-score-sort="target">Hedef <span></span></button></th>
                    <th class="text-end"><button class="sort-button score-sort-button justify-content-end" type="button" data-score-sort="hgo">HGO <span></span></button></th>
                    <th class="text-end"><button class="sort-button score-sort-button justify-content-end" type="button" data-score-sort="development">Gelişim <span></span></button></th>
                    <th class="text-end"><button class="sort-button score-sort-button justify-content-end" type="button" data-score-sort="size">Büyüklük <span></span></button></th>
                    <th class="text-end"><button class="sort-button score-sort-button justify-content-end" type="button" data-score-sort="success">Başarı <span></span></button></th>
                    <th class="text-end">İşlem</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Scores.Count == 0)
            {
                <tr>
                    <td colspan="14" class="empty-cell">Puan satırı yok</td>
                </tr>
            }
            @foreach (var score in Model.Scores)
            {
                var search = $"{score.Year} {score.Term} {score.GroupNo} {score.GroupName} {score.BranchCode} {score.BranchName} {score.MainProductCode} {score.MainProductName} {score.SubProductCode} {score.SubProductName}".ToUpperInvariant();
                var successLevel = SuccessLevel(score.SuccessRate);
                <tr class="score-row"
                    data-search="@search"
                    data-group-id="@score.GroupId"
                    data-branch-id="@score.BranchId"
                    data-year="@score.Year"
                    data-term="@score.Term"
                    data-group="@($"{score.GroupNo} {score.GroupName}")"
                    data-branch="@($"{score.BranchCode} {score.BranchName}")"
                    data-main="@($"{score.MainProductCode} {score.MainProductName}")"
                    data-sub="@($"{score.SubProductCode} {score.SubProductName}")"
                    data-score="@score.Score"
                    data-displayed="@score.DisplayedScore"
                    data-target="@score.TargetValue"
                    data-hgo="@score.HgoShare"
                    data-development="@score.DevelopmentShare"
                    data-size="@score.SizeShare"
                    data-success="@score.SuccessRate">
                    <td>@score.Year</td>
                    <td>@score.Term</td>
                    <td><strong>@score.GroupNo</strong><small>@score.GroupName</small></td>
                    <td><strong class="success-name @successLevel">@score.BranchCode</strong><small>@score.BranchName</small></td>
                    <td><strong>@score.MainProductCode</strong><small>@score.MainProductName</small></td>
                    <td><strong class="success-name @successLevel">@score.SubProductCode</strong><small>@score.SubProductName</small></td>
                    <td class="text-end">@Fmt(score.Score)</td>
                    <td class="text-end">@Fmt(score.DisplayedScore)</td>
                    <td class="text-end">@Fmt(score.TargetValue)</td>
                    <td class="text-end">@Pct(score.HgoShare)</td>
                    <td class="text-end">@Pct(score.DevelopmentShare)</td>
                    <td class="text-end">@Pct(score.SizeShare)</td>
                    <td class="text-end"><span class="success-chip @successLevel">@Pct(score.SuccessRate)</span></td>
                    <td class="text-end">
                        <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="collapse" data-bs-target="#score-actions-@score.Id">Detay</button>
                    </td>
                </tr>
                <tr class="score-actions-row">
                    <td colspan="14">
                        <div class="collapse" id="score-actions-@score.Id">
                            <div class="actions-panel">
                                <div class="score-detail-panel @successLevel">
                                    <div class="score-detail-hero">
                                        <div>
                                            <span class="detail-kicker">@score.GroupNo / @score.BranchCode</span>
                                            <strong>@score.BranchName</strong>
                                            <small>@score.MainProductCode - @score.SubProductCode @score.SubProductName</small>
                                        </div>
                                        <div class="success-dial @successLevel">
                                            <span>@Pct(score.SuccessRate)</span>
                                            <small>@SuccessText(score.SuccessRate)</small>
                                        </div>
                                    </div>
                                    <div class="detail-metrics-grid">
                                        <div class="detail-metric">
                                            <span>Puan / hedef</span>
                                            <strong>@Fmt(score.Score) / @Fmt(score.TargetValue)</strong>
                                            <div class="mini-progress">
                                                <div style="width:@Width(score.SuccessRate)%"></div>
                                            </div>
                                        </div>
                                        <div class="detail-metric">
                                            <span>Görüntülenecek puan</span>
                                            <strong>@Fmt(score.DisplayedScore)</strong>
                                            <div class="mini-progress muted-progress">
                                                <div style="width:@Width(score.DisplayedScore)%"></div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="share-stack" aria-label="Pay dağılımı">
                                        <div class="share hgo" style="width:@Width(score.HgoShare)%">HGO @Pct(score.HgoShare)</div>
                                        <div class="share development" style="width:@Width(score.DevelopmentShare)%">Gelişim @Pct(score.DevelopmentShare)</div>
                                        <div class="share size" style="width:@Width(score.SizeShare)%">Büyüklük @Pct(score.SizeShare)</div>
                                    </div>
                                </div>
                                <form asp-action="UpdateScore" method="post" class="inline-form score-edit-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="Id" value="@score.Id" />
                                    <input type="hidden" name="BranchId" value="@score.BranchId" />
                                    <input type="hidden" name="SubProductInstanceId" value="@score.SubProductInstanceId" />
                                    <label>
                                        <span>Puan</span>
                                        <input class="form-control form-control-sm decimal-input" name="Score" inputmode="decimal" value="@Fmt(score.Score)" />
                                    </label>
                                    <label>
                                        <span>Hedef</span>
                                        <input class="form-control form-control-sm decimal-input" name="TargetValue" inputmode="decimal" value="@Fmt(score.TargetValue)" />
                                    </label>
                                    <label>
                                        <span>HGO %</span>
                                        <input class="form-control form-control-sm decimal-input" name="HgoShare" inputmode="decimal" value="@Fmt(score.HgoShare)" />
                                    </label>
                                    <label>
                                        <span>Gelişim %</span>
                                        <input class="form-control form-control-sm decimal-input" name="DevelopmentShare" inputmode="decimal" value="@Fmt(score.DevelopmentShare)" />
                                    </label>
                                    <label>
                                        <span>Büyüklük %</span>
                                        <input class="form-control form-control-sm decimal-input" name="SizeShare" inputmode="decimal" value="@Fmt(score.SizeShare)" />
                                    </label>
                                    <button class="btn btn-sm btn-outline-primary" type="submit" data-confirm="Puan satırını güncellemek istediğinize emin misiniz?">Güncelle</button>
                                </form>
                                <form asp-action="DeleteScore" method="post" class="button-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="Id" value="@score.Id" />
                                    <button class="btn btn-sm btn-outline-danger" type="submit" data-confirm="Puan satırını silmek istediğinize emin misiniz?">Sil</button>
                                </form>
                            </div>
                        </div>
                    </td>
                </tr>
            }
            <tr id="noScoreRows" class="empty-row d-none">
                <td colspan="14" class="empty-cell">Filtreye uygun puan satırı yok</td>
            </tr>
            </tbody>
        </table>
    </div>
</section>
