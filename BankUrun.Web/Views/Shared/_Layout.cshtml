<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="icon" type="image/jpeg" href="~/img/halkbank-logo.jpg" />
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BankUrun.Web.styles.css" asp-append-version="true" />
</head>
<body>
    @{ var controller = ViewContext.RouteData.Values["controller"]?.ToString(); }
    <div class="app-frame">
        <aside class="app-sidebar">
            <a class="brand-mark" asp-controller="Dashboard" asp-action="Index" aria-label="Dashboard">
                <img src="~/img/halkbank-logo.jpg" alt="Halkbank" />
            </a>
            <nav class="app-nav" aria-label="Ana menü">
                <a class="app-nav-link @(controller == "Dashboard" ? "is-active" : "")" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                <a class="app-nav-link @(controller == "Parameters" ? "is-active" : "")" asp-controller="Parameters" asp-action="Index">Parametreler</a>
                <a class="app-nav-link @(controller == "Products" ? "is-active" : "")" asp-controller="Products" asp-action="Index">Ürün Kataloğu</a>
                <a class="app-nav-link @(controller == "Organization" ? "is-active" : "")" asp-controller="Organization" asp-action="Index">Organizasyon</a>
            </nav>
            <div class="sidebar-note">Ana ürün performans ve parametre yönetimi</div>
        </aside>
        <div class="app-main">
            <main class="app-shell" role="main">
                @RenderBody()
            </main>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
