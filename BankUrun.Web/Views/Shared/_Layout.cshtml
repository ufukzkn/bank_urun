<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BankUrun.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="app-header">
        <div class="container app-header-inner">
            <a class="brand-mark" asp-controller="Products" asp-action="Index" aria-label="Ana sayfa">
                <img src="~/img/halkbank-logo.jpg" alt="Halkbank" />
            </a>
            <nav class="app-nav" aria-label="Ana menü">
                <a class="app-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Products" ? "is-active" : "")" asp-controller="Products" asp-action="Index">Ürünler</a>
                <a class="app-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Organization" ? "is-active" : "")" asp-controller="Organization" asp-action="Index">Organizasyon</a>
                <a class="app-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Scores" ? "is-active" : "")" asp-controller="Scores" asp-action="Index">Puanlar</a>
            </nav>
        </div>
    </header>
    <div class="container app-shell">
        <main role="main">
            @RenderBody()
        </main>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
