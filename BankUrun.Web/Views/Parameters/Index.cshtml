@using BankUrun.Web.Models
@model BankUrun.Web.ViewModels.ParameterIndexViewModel

@{
    ViewData["Title"] = "Parametreler";
    var selectedBranch = Model.Branches.FirstOrDefault(branch => branch.Id == Model.SelectedBranchId);
}

<section class="page-title parameter-page-title">
    <div>
        <h1>Parametreler</h1>
        <p>Şube ve dönem bağlamında ana ürün hedeflerini ve hesaplanan puanları yönetin.</p>
    </div>
    <span class="batch-date">Batch tarihi <strong>@Model.BatchDate.ToString("dd.MM.yyyy")</strong></span>
</section>

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success action-alert page-alert" role="alert">@success</div>
}
@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger action-alert page-alert" role="alert">@error</div>
}

<section class="parameter-workspace"
         data-list="parameters"
         data-list-page="@Model.Page.Page"
         data-list-total-pages="@Model.Page.TotalPages"
         data-list-total-count="@Model.Page.TotalCount"
         data-rows-url="@Url.Action("Rows", "Parameters")">
    <div class="surface-panel parameter-context-panel">
        <div class="parameter-context-heading">
            <h2>Çalışma bağlamı</h2>
            <p>Açık dönem hesapları mevcut batch ayına kadar olan veriyi kullanır.</p>
        </div>
        <div class="parameter-context-grid">
            <label class="parameter-branch-field">
                <span>Şube</span>
                <div class="combo generic-combo">
                    <input class="form-control" type="search" autocomplete="off" value="@selectedBranch?.Label" placeholder="Kod veya şube adı ara" data-combo-input />
                    <input type="hidden" value="@Model.SelectedBranchId" data-combo-value data-list-filter="branchId" />
                    <div class="combo-menu parameter-branch-menu">
                        @foreach (var branch in Model.Branches)
                        {
                            <button class="combo-option" type="button" data-combo-option data-id="@branch.Id" data-label="@branch.Label">
                                <strong>@branch.BranchCode</strong>
                                <span>@branch.Name</span>
                                <small>@branch.GroupSegment</small>
                                <small class="combo-option-description">@branch.GroupNo - @branch.GroupName</small>
                            </button>
                        }
                        <div class="combo-empty">Eşleşen şube bulunamadı.</div>
                    </div>
                </div>
            </label>
            <label>
                <span>Yıl</span>
                <select class="form-select" data-list-filter="year">
                    @foreach (var year in Model.Years)
                    {
                        <option value="@year" selected="@(year == Model.SelectedYear)">@year</option>
                    }
                </select>
            </label>
            <label>
                <span>Dönem</span>
                <select class="form-select" data-list-filter="term">
                    <option value="1" selected="@(Model.SelectedTerm == 1)">1. Dönem (Ocak-Haziran)</option>
                    <option value="2" selected="@(Model.SelectedTerm == 2)">2. Dönem (Temmuz-Aralık)</option>
                </select>
            </label>
        </div>
    </div>

    <div class="surface-panel table-panel parameter-table-panel">
        <div class="panel-heading table-panel-heading">
            <div>
                <h2>Ana ürün parametreleri</h2>
                <p>H/G ve puanlar aylık ara değerlerden anlık hesaplanır.</p>
            </div>
        </div>
        <div class="table-toolbar parameter-toolbar">
            <label class="toolbar-search">
                <span>Ürün ara</span>
                <input class="form-control" type="search" data-list-filter="search" placeholder="Ana ürün kodu veya adı" />
            </label>
            <label>
                <span>Hesaplama</span>
                <select class="form-select" data-list-filter="calculationType">
                    <option value="">Tümü</option>
                    <option value="Average">Ortalamalı</option>
                    <option value="Cumulative">Kümülatif</option>
                </select>
            </label>
            <label>
                <span>Sayfa</span>
                <select class="form-select" data-list-page-size>
                    <option value="5">5</option>
                    <option value="10" selected>10</option>
                    <option value="25">25</option>
                    <option value="50">50</option>
                </select>
            </label>
        </div>
        <div class="table-responsive parameter-table-scroll">
            <table class="table compact-table parameter-table">
                <thead>
                    <tr>
                        <th><button class="sort-button" type="button" data-list-sort="product">Ana ürün <span></span></button></th>
                        <th><button class="sort-button" type="button" data-list-sort="calculation">Hesaplama <span></span></button></th>
                        <th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="criterion">Kriter puanı <span></span></button></th>
                        <th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="target">Hedef <span></span></button></th>
                        <th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="actual">Gerçekleşme <span></span></button></th>
                        <th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="ratio">H/G <span></span></button></th>
                        <th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="hgo">HGO puanı <span></span></button></th>
                        <th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="total">Toplam puan <span></span></button></th>
                        <th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="productRank">Ürün sırası <span></span></button></th>
                        <th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="segmentRank">Segment sırası <span></span></button></th>
                        <th class="text-end">İşlem</th>
                    </tr>
                </thead>
                <tbody data-remote-list-body>
                    @await Html.PartialAsync("_ParameterRows", Model.Page)
                </tbody>
            </table>
        </div>
        <div class="pagination-bar" data-list-pagination>
            <div class="pagination-summary" data-list-summary>Parametreler hazırlanıyor</div>
            <div class="pager-buttons">
                <button class="btn btn-sm btn-outline-secondary icon-btn" type="button" data-list-page="first" aria-label="İlk sayfa" title="İlk sayfa">«</button>
                <button class="btn btn-sm btn-outline-secondary icon-btn" type="button" data-list-page="previous" aria-label="Önceki sayfa" title="Önceki sayfa">‹</button>
                <span data-list-page-indicator>1 / 1</span>
                <input class="form-control form-control-sm page-jump" type="number" min="1" value="1" data-list-page-jump aria-label="Sayfa numarası" />
                <button class="btn btn-sm btn-outline-secondary" type="button" data-list-page="jump">Git</button>
                <button class="btn btn-sm btn-outline-secondary icon-btn" type="button" data-list-page="next" aria-label="Sonraki sayfa" title="Sonraki sayfa">›</button>
                <button class="btn btn-sm btn-outline-secondary icon-btn" type="button" data-list-page="last" aria-label="Son sayfa" title="Son sayfa">»</button>
            </div>
        </div>
    </div>
</section>
