@using BankUrun.Web.Models
@model BankUrun.Web.ViewModels.ParameterIndexViewModel

@{ ViewData["Title"] = "Parametreler"; }

<section class="page-title parameter-page-title">
    <div><h1>Parametreler</h1><p>Grup ve ana ürün dönem kurallarını yönetin.</p></div>
</section>

@if (TempData["Success"] is string success) { <div class="alert alert-success action-alert page-alert" role="alert">@success</div> }
@if (TempData["Error"] is string error) { <div class="alert alert-danger action-alert page-alert" role="alert">@error</div> }

<section class="surface-panel compact-create-panel performance-create-panel parameter-create-panel">
    <div class="panel-heading"><div><h2>Yeni ürün performans kuralı</h2><p>Grup, dönemsel ana ürün, hesaplama türü ve toplam puanı seçin.</p></div></div>
    <form asp-action="SaveParameter" method="post" class="compact-parameter-create-form">
        @Html.AntiForgeryToken()
        <label><span>Grup</span><div class="combo generic-combo"><input class="form-control" type="search" autocomplete="off" placeholder="Grup no veya adı ara" data-combo-input /><input type="hidden" name="GroupId" data-combo-value data-combo-required="Grup seçmelisiniz." /><div class="combo-menu">@foreach (var group in Model.Groups) { <button class="combo-option" type="button" data-combo-option data-id="@group.Id" data-label="@group.Label"><strong>@group.GroupNo</strong><span>@group.Name</span><small>@group.GroupSegment</small></button> }<div class="combo-empty">Grup bulunamadı.</div></div></div></label>
        <label class="parameter-product-field"><span>Ana ürün / dönem</span><div class="combo generic-combo"><input class="form-control" type="search" autocomplete="off" placeholder="Yıl, kod veya ürün adı ara" data-combo-input /><input type="hidden" name="MainProductInstanceId" data-combo-value data-combo-required="Ana ürün dönemi seçmelisiniz." /><div class="combo-menu parameter-product-menu">@foreach (var product in Model.Products) { <button class="combo-option" type="button" data-combo-option data-id="@product.Id" data-label="@product.Label"><strong>@product.Code</strong><span>@product.Name</span><small>@product.Year / @product.Term. Dönem</small></button> }<div class="combo-empty">Ana ürün dönemi bulunamadı.</div></div></div></label>
        <label><span>Hesaplama</span><select class="form-select" name="CalculationType"><option value="Average">Ortalamalı</option><option value="Cumulative">Kümülatif</option></select></label>
        <label><span>Toplam puan</span><input class="form-control numeric-input" type="number" name="CriterionScore" min="0" step="0.01" value="100" required /></label>
        <input type="hidden" name="IsActive" value="true" />
        <button class="btn btn-primary" type="submit">Kural oluştur</button>
    </form>
</section>

<section class="surface-panel table-panel compact-list-panel parameter-management-list"
         data-list="parameters"
         data-list-page="@Model.Page.Page"
         data-list-total-pages="@Model.Page.TotalPages"
         data-list-total-count="@Model.Page.TotalCount"
         data-rows-url="@Url.Action("Rows", "Parameters")"
         data-target-editor-url="@Url.Action("TargetEditor", "Parameters")">
    <div class="panel-heading"><div><h2>Tanımlı parametreler</h2><p>Puan ve segment dağılımlarını detaydan yönetin.</p></div></div>
    <div class="table-toolbar performance-list-toolbar parameter-list-toolbar">
        <label class="toolbar-search"><span>Parametrelerde ara</span><input class="form-control" type="search" data-list-filter="search" placeholder="Grup veya ana ürün" /></label>
        <label><span>Grup</span><select class="form-select" data-list-filter="groupId"><option value="">Tümü</option>@foreach (var group in Model.Groups) { <option value="@group.Id">@group.GroupNo</option> }</select></label>
        <label><span>Yıl</span><select class="form-select" data-list-filter="year"><option value="">Tümü</option>@foreach (var year in Model.Years) { <option value="@year">@year</option> }</select></label>
        <label><span>Dönem</span><select class="form-select" data-list-filter="term"><option value="">Tümü</option><option value="1">1. Dönem</option><option value="2">2. Dönem</option></select></label>
        <label><span>Hesaplama</span><select class="form-select" data-list-filter="calculationType"><option value="">Tümü</option><option value="Average">Ortalamalı</option><option value="Cumulative">Kümülatif</option></select></label>
        <label><span>Sayfa</span><select class="form-select" data-list-page-size><option value="5">5</option><option value="10" selected>10</option><option value="25">25</option><option value="50">50</option></select></label>
    </div>
    <div class="table-responsive parameter-table-scroll"><table class="table compact-table performance-parameter-table"><thead><tr>
        <th><button class="sort-button" type="button" data-list-sort="year">Yıl <span></span></button></th>
        <th><button class="sort-button" type="button" data-list-sort="term">Dönem <span></span></button></th>
        <th><button class="sort-button" type="button" data-list-sort="group">Grup <span></span></button></th>
        <th><button class="sort-button" type="button" data-list-sort="product">Ana ürün <span></span></button></th>
        <th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="criterion">Toplam puan <span></span></button></th>
        <th><button class="sort-button" type="button" data-list-sort="active">Durum <span></span></button></th><th class="text-end">İşlem</th>
    </tr></thead><tbody data-remote-list-body>@await Html.PartialAsync("_ParameterRows", Model.Page)</tbody></table></div>
    <div class="pagination-bar" data-list-pagination><div class="pagination-summary" data-list-summary>Parametreler hazırlanıyor</div><div class="pager-buttons">
        <button class="btn btn-sm btn-outline-secondary icon-btn" type="button" data-list-page="first" title="İlk sayfa">«</button><button class="btn btn-sm btn-outline-secondary icon-btn" type="button" data-list-page="previous" title="Önceki sayfa">‹</button><span data-list-page-indicator>1 / 1</span><input class="form-control form-control-sm page-jump" type="number" min="1" value="1" data-list-page-jump aria-label="Sayfa numarası" /><button class="btn btn-sm btn-outline-secondary" type="button" data-list-page="jump">Git</button><button class="btn btn-sm btn-outline-secondary icon-btn" type="button" data-list-page="next" title="Sonraki sayfa">›</button><button class="btn btn-sm btn-outline-secondary icon-btn" type="button" data-list-page="last" title="Son sayfa">»</button>
    </div></div>
</section>
