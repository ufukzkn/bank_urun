@model BankUrun.Web.ViewModels.SubProductTargetPageViewModel

@if (Model.Rows.Count == 0) { <tr class="empty-row"><td colspan="5" class="empty-cell">Filtreye uygun alt ürün bulunamadı.</td></tr> }
@foreach (var row in Model.Rows)
{
    var detailId = $"sub-product-target-{row.SubProductId}-{row.Year}-{row.Term}";
    <tr class="list-row" data-detail-id="@detailId">
        <td>@row.Year</td><td>@row.Term. Dönem</td>
        <td><strong>@row.SubProductCode</strong><small>@row.SubProductName</small></td>
        <td><div class="linked-product-badges">@foreach (var parent in row.ParentProducts) { <span title="@parent.Name">@parent.Code · @parent.Name</span> }</div></td>
        <td class="text-end"><button class="btn btn-sm btn-outline-primary detail-button" type="button" data-bs-toggle="collapse" data-bs-target="#@detailId">Detay</button></td>
    </tr>
    <tr class="list-detail-row" data-detail-for="@detailId"><td colspan="5"><div class="collapse" id="@detailId"><div class="sub-product-target-detail">
        <div class="detail-section-heading"><h3>@row.SubProductCode · @row.SubProductName</h3><p>Ortak alt ürün hedefindeki değişiklik, bağlı olduğu tüm ana ürünlerin hesabını etkiler.</p></div>
        <label class="target-branch-selector"><span>Şube</span><div class="combo generic-combo"><input class="form-control form-control-sm" type="search" autocomplete="off" placeholder="Şube kodu veya adı" data-combo-input /><input type="hidden" value="" data-combo-value data-sub-target-branch data-sub-product-id="@row.SubProductId" data-year="@row.Year" data-term="@row.Term" /><div class="combo-menu">@foreach (var branch in row.Branches) { <button class="combo-option" type="button" data-combo-option data-id="@branch.Id" data-label="@branch.Label"><strong>@branch.BranchCode</strong><span>@branch.Name</span><small>@branch.GroupNo</small></button> }<div class="combo-empty">Şube bulunamadı.</div></div></div></label>
        <div data-sub-target-editor><div class="inline-empty-state">Aylık hedefleri görüntülemek için şube seçin.</div></div>
    </div></div></td></tr>
}
