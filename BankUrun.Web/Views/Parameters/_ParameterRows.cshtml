@using BankUrun.Web.Models
@model BankUrun.Web.ViewModels.ParameterPageViewModel

@functions {
    private static string Calculation(MainProductCalculationType type) =>
        type == MainProductCalculationType.Average ? "Ortalamalı" : "Kümülatif";
    private static string Fmt(decimal value) => value.ToString("0.##");
}

@if (Model.Rows.Count == 0)
{
    <tr class="empty-row"><td colspan="7" class="empty-cell">Filtreye uygun parametre yok</td></tr>
}

@foreach (var row in Model.Rows)
{
    var detailId = $"parameter-detail-{row.ParameterId}";
    <tr class="list-row performance-parameter-row" data-detail-id="@detailId">
        <td>@row.Year</td>
        <td>@row.Term</td>
        <td><strong>@row.GroupNo</strong><small>@row.GroupName</small></td>
        <td><strong>@row.MainProductCode</strong><small>@row.MainProductName · @Calculation(row.CalculationType)</small></td>
        <td class="text-end numeric-cell">@row.CriterionScore.ToString("N2")</td>
        <td><span class="status-pill @(row.IsActive ? "active" : "passive")">@(row.IsActive ? "Aktif" : "Pasif")</span></td>
        <td class="text-end"><button class="btn btn-sm btn-outline-primary detail-button" type="button" data-bs-toggle="collapse" data-bs-target="#@detailId">Detay</button></td>
    </tr>
    <tr class="list-detail-row" data-detail-for="@detailId">
        <td colspan="7">
            <div class="collapse" id="@detailId">
                <div class="performance-parameter-detail">
                    <form asp-controller="Parameters" asp-action="SaveParameter" method="post" class="parameter-editor-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="Id" value="@row.ParameterId" />
                        <input type="hidden" name="GroupId" value="@row.GroupId" />
                        <input type="hidden" name="MainProductInstanceId" value="@row.MainProductInstanceId" />
                        <div class="parameter-editor-heading">
                            <label><span>Toplam puan</span><input class="form-control form-control-sm numeric-input" type="number" name="CriterionScore" value="@Fmt(row.CriterionScore)" min="0" step="0.01" required /></label>
                            <label><span>Hesaplama</span><select class="form-select form-select-sm" name="CalculationType"><option value="Average" selected="@(row.CalculationType == MainProductCalculationType.Average)">Ortalamalı</option><option value="Cumulative" selected="@(row.CalculationType == MainProductCalculationType.Cumulative)">Kümülatif</option></select></label>
                            <label class="check-line"><input class="form-check-input" type="checkbox" name="IsActive" value="true" checked="@row.IsActive" /><input type="hidden" name="IsActive" value="false" /><span>Aktif kural</span></label>
                        </div>
                        <div class="table-responsive segment-editor-scroll">
                            <table class="table segment-editor-table">
                                <thead><tr><th>Segment</th><th>Sıra</th><th>Hedef %</th><th>Büyüklük %</th><th>Ölçek %</th><th>Puan</th><th>HGO payı %</th><th>Gelişim payı %</th><th>Büyüklük payı %</th></tr></thead>
                                <tbody>
                                @for (var index = 0; index < row.Rules.Count; index++)
                                {
                                    var rule = row.Rules[index];
                                    <tr>
                                        <td><strong>@rule.PerformanceSegment</strong><input type="hidden" name="Rules[@index].Id" value="@rule.Id" /><input type="hidden" name="Rules[@index].PerformanceSegment" value="@rule.PerformanceSegment" /></td>
                                        <td><input class="form-control form-control-sm" type="number" name="Rules[@index].SortOrder" value="@rule.SortOrder" min="1" required /></td>
                                        <td><input class="form-control form-control-sm numeric-input" type="number" name="Rules[@index].TargetShare" value="@Fmt(rule.TargetShare)" min="0" max="100" step="0.01" /></td>
                                        <td><input class="form-control form-control-sm numeric-input" type="number" name="Rules[@index].SizeShare" value="@Fmt(rule.SizeShare)" min="0" max="100" step="0.01" /></td>
                                        <td><input class="form-control form-control-sm numeric-input" type="number" name="Rules[@index].ScaleShare" value="@Fmt(rule.ScaleShare)" min="0" max="100" step="0.01" /></td>
                                        <td><input class="form-control form-control-sm numeric-input" type="number" name="Rules[@index].AllocatedScore" value="@Fmt(rule.AllocatedScore)" min="0" step="0.01" /></td>
                                        <td><input class="form-control form-control-sm numeric-input" type="number" name="Rules[@index].HgoWeight" value="@Fmt(rule.HgoWeight)" min="0" max="100" step="0.01" /></td>
                                        <td><input class="form-control form-control-sm numeric-input" type="number" name="Rules[@index].DevelopmentWeight" value="@Fmt(rule.DevelopmentWeight)" min="0" max="100" step="0.01" /></td>
                                        <td><input class="form-control form-control-sm numeric-input" type="number" name="Rules[@index].SizeWeight" value="@Fmt(rule.SizeWeight)" min="0" max="100" step="0.01" /></td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                        <div class="detail-command-row">
                            <button class="btn btn-sm btn-primary" type="submit" data-confirm="Parametre ve segment dağılımını güncellemek istediğinize emin misiniz?">Dağılımı kaydet</button>
                            <button class="btn btn-sm btn-outline-secondary" type="button" data-show-sub-products data-main-product-id="@row.MainProductInstanceId" data-year="@row.Year" data-term="@row.Term" data-group-id="@row.GroupId">Alt ürünleri gör</button>
                            <button class="btn btn-sm btn-outline-danger" type="submit" form="delete-parameter-@row.ParameterId" data-confirm="Parametreyi ve bağlı aylık verileri silmek istediğinize emin misiniz?">Kuralı sil</button>
                        </div>
                    </form>
                    <form id="delete-parameter-@row.ParameterId" asp-controller="Parameters" asp-action="DeleteParameter" method="post" class="button-form">
                        @Html.AntiForgeryToken()<input type="hidden" name="Id" value="@row.ParameterId" />
                    </form>
                </div>
            </div>
        </td>
    </tr>
}
