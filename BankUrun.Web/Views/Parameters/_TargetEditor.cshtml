@model BankUrun.Web.ViewModels.ParameterTargetEditorViewModel
<form asp-controller="Parameters" asp-action="UpdateTargets" method="post" class="monthly-target-form">
    @Html.AntiForgeryToken()<input type="hidden" name="ParameterId" value="@Model.ParameterId" /><input type="hidden" name="BranchId" value="@Model.BranchId" />
    <div class="monthly-metric-grid">@for (var index = 0; index < Model.Months.Count; index++) { var month = Model.Months[index]; <div class="month-metric-card"><div class="month-metric-heading"><strong>@month.MonthName</strong>@if (month.ActualValue.HasValue) { <span>Batch geldi</span> } else { <span class="is-waiting">Batch bekliyor</span> }</div><input type="hidden" name="Months[@index].Month" value="@month.Month" /><label><span>Hedef</span><input class="form-control form-control-sm numeric-input" type="number" name="Months[@index].TargetValue" value="@month.TargetValue" min="0" step="0.01" required /></label><div class="readonly-metric"><span>Gerçekleşme</span><strong>@(month.ActualValue?.ToString("N2") ?? "-")</strong><small>@(month.ActualAsOfDate?.ToString("dd.MM.yyyy") ?? "Veri bekleniyor")</small></div></div> }</div>
    <div class="detail-command-row monthly-save-row"><button class="btn btn-sm btn-primary" type="submit" data-confirm="Seçili şubenin aylık hedeflerini güncellemek istediğinize emin misiniz?">Hedefleri güncelle</button></div>
</form>
