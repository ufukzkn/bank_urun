@using BankUrun.Web.Models
@model BankUrun.Web.ViewModels.OrganizationIndexViewModel

@{
    ViewData["Title"] = "Organizasyon";
}

<section class="page-title">
    <div>
        <h1>Organizasyon</h1>
        <p>Gruplar ve bu gruplara bağlı şubeler.</p>
    </div>
</section>

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success action-alert page-alert" role="alert">@success</div>
}

@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger action-alert page-alert" role="alert">@error</div>
}

<section class="management-grid links-grid">
    <div class="surface-panel create-panel">
        <div class="panel-heading">
            <div>
                <h2>Grup oluştur</h2>
                <p>Segment ve performans kapsamı ile tanımlayın.</p>
            </div>
        </div>
        <form asp-action="CreateGroup" method="post" class="stack-form">
            @Html.AntiForgeryToken()
            <div class="form-row">
                <label>
                    <span>Grup no</span>
                    <input class="form-control code-input" name="GroupNo" maxlength="24" required />
                </label>
                <label>
                    <span>Segment</span>
                    <select class="form-select" name="GroupSegment" required>
                        @foreach (var segment in Enum.GetValues<GroupSegment>())
                        {
                            <option value="@segment">@segment</option>
                        }
                    </select>
                </label>
            </div>
            <label>
                <span>Grup adı</span>
                <input class="form-control" name="Name" maxlength="180" required />
            </label>
            <div class="toggle-grid">
                <label class="check-line">
                    <input class="form-check-input" type="checkbox" name="IsActive" value="true" checked />
                    <input type="hidden" name="IsActive" value="false" />
                    <span>Aktif</span>
                </label>
                <label class="check-line">
                    <input class="form-check-input" type="checkbox" name="BranchPerformanceEnabled" value="true" checked />
                    <input type="hidden" name="BranchPerformanceEnabled" value="false" />
                    <span>Şube performans</span>
                </label>
                <label class="check-line">
                    <input class="form-check-input" type="checkbox" name="MiyPerformanceEnabled" value="true" checked />
                    <input type="hidden" name="MiyPerformanceEnabled" value="false" />
                    <span>MİY performans</span>
                </label>
                <label class="check-line">
                    <input class="form-check-input" type="checkbox" name="ScaleEnabled" value="true" checked />
                    <input type="hidden" name="ScaleEnabled" value="false" />
                    <span>Ölçek</span>
                </label>
            </div>
            <button class="btn btn-primary" type="submit">Grup oluştur</button>
        </form>
    </div>

    <div class="surface-panel create-panel">
        <div class="panel-heading">
            <div>
                <h2>Şube oluştur</h2>
                <p>Şubeyi tek bir gruba bağlayın.</p>
            </div>
        </div>
        <form asp-action="CreateBranch" method="post" class="stack-form">
            @Html.AntiForgeryToken()
            <label>
                <span>Bağlı grup</span>
                <select class="form-select searchable-native" name="GroupId" required>
                    @foreach (var group in Model.Groups.Where(group => group.IsActive))
                    {
                        <option value="@group.Id">@group.Label (@group.GroupSegment)</option>
                    }
                </select>
            </label>
            <div class="form-row">
                <label>
                    <span>Şube kodu</span>
                    <input class="form-control code-input" name="BranchCode" maxlength="24" required />
                </label>
                <label>
                    <span>Şube adı</span>
                    <input class="form-control" name="Name" maxlength="180" required />
                </label>
            </div>
            <button class="btn btn-primary" type="submit">Şube oluştur</button>
        </form>
    </div>
</section>

<section class="surface-panel table-panel">
    <div class="table-toolbar simple-toolbar">
        <label class="toolbar-search">
            <span>Organizasyon içinde ara</span>
            <input class="form-control live-table-filter" type="search" data-target=".organization-row" placeholder="Grup no, segment, şube kodu veya adı" />
        </label>
    </div>

    <div class="org-board">
        @foreach (var group in Model.Groups)
        {
            var groupBranches = Model.Branches.Where(branch => branch.GroupId == group.Id).ToList();
            var search = $"{group.GroupNo} {group.Name} {group.GroupSegment} {string.Join(' ', groupBranches.Select(branch => $"{branch.BranchCode} {branch.Name}"))}".ToUpperInvariant();
            <article class="group-card organization-row" data-search="@search">
                <div class="group-card-header">
                    <div>
                        <div class="group-code">@group.GroupNo</div>
                        <h2>@group.Name</h2>
                        <div class="group-meta">
                            <span class="status-pill neutral">@group.GroupSegment</span>
                            <span class="status-pill @(group.IsActive ? "active" : "passive")">@(group.IsActive ? "Aktif" : "Pasif")</span>
                            <span>@group.BranchCount şube</span>
                        </div>
                    </div>
                    <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="collapse" data-bs-target="#group-edit-@group.Id">Düzenle</button>
                </div>

                <div class="performance-flags">
                    <span class="flag-pill @(group.BranchPerformanceEnabled ? "is-on" : "")">Şube perf.</span>
                    <span class="flag-pill @(group.MiyPerformanceEnabled ? "is-on" : "")">MİY perf.</span>
                    <span class="flag-pill @(group.ScaleEnabled ? "is-on" : "")">Ölçek</span>
                </div>

                <div class="collapse" id="group-edit-@group.Id">
                    <div class="inline-edit-panel">
                        <form asp-action="UpdateGroup" method="post" class="stack-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="Id" value="@group.Id" />
                            <div class="form-row">
                                <label>
                                    <span>Grup no</span>
                                    <input class="form-control code-input" name="GroupNo" value="@group.GroupNo" maxlength="24" required />
                                </label>
                                <label>
                                    <span>Segment</span>
                                    <select class="form-select" name="GroupSegment">
                                        @foreach (var segment in Enum.GetValues<GroupSegment>())
                                        {
                                            <option value="@segment" selected="@(group.GroupSegment == segment)">@segment</option>
                                        }
                                    </select>
                                </label>
                            </div>
                            <label>
                                <span>Grup adı</span>
                                <input class="form-control" name="Name" value="@group.Name" maxlength="180" required />
                            </label>
                            <div class="toggle-grid">
                                <label class="check-line">
                                    <input class="form-check-input" type="checkbox" name="IsActive" value="true" checked="@group.IsActive" />
                                    <input type="hidden" name="IsActive" value="false" />
                                    <span>Aktif</span>
                                </label>
                                <label class="check-line">
                                    <input class="form-check-input" type="checkbox" name="BranchPerformanceEnabled" value="true" checked="@group.BranchPerformanceEnabled" />
                                    <input type="hidden" name="BranchPerformanceEnabled" value="false" />
                                    <span>Şube performans</span>
                                </label>
                                <label class="check-line">
                                    <input class="form-check-input" type="checkbox" name="MiyPerformanceEnabled" value="true" checked="@group.MiyPerformanceEnabled" />
                                    <input type="hidden" name="MiyPerformanceEnabled" value="false" />
                                    <span>MİY performans</span>
                                </label>
                                <label class="check-line">
                                    <input class="form-check-input" type="checkbox" name="ScaleEnabled" value="true" checked="@group.ScaleEnabled" />
                                    <input type="hidden" name="ScaleEnabled" value="false" />
                                    <span>Ölçek</span>
                                </label>
                            </div>
                            <button class="btn btn-sm btn-outline-primary" type="submit" data-confirm="Grubu güncellemek istediğinize emin misiniz?">Güncelle</button>
                        </form>
                        <div class="form-actions">
                                <form asp-action="DeleteGroup" method="post" class="button-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="Id" value="@group.Id" />
                                    <button class="btn btn-sm btn-outline-danger" type="submit" data-confirm="Grubu silmek istediğinize emin misiniz? Bağlı şube varsa silinmez.">Sil</button>
                                </form>
                        </div>
                    </div>
                </div>

                <div class="branch-list">
                    @if (groupBranches.Count == 0)
                    {
                        <div class="empty-inline">Bu gruba bağlı şube yok</div>
                    }
                    @foreach (var branch in groupBranches)
                    {
                        <div class="branch-row">
                            <div>
                                <strong>@branch.BranchCode</strong>
                                <span>@branch.Name</span>
                            </div>
                            <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#branch-edit-@branch.Id">Düzenle</button>
                        </div>
                        <div class="collapse" id="branch-edit-@branch.Id">
                            <div class="inline-edit-panel compact">
                                <form asp-action="UpdateBranch" method="post" class="inline-form branch-edit-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="Id" value="@branch.Id" />
                                    <select class="form-select form-select-sm compact-select" name="GroupId">
                                        @foreach (var targetGroup in Model.Groups)
                                        {
                                            <option value="@targetGroup.Id" selected="@(targetGroup.Id == branch.GroupId)">@targetGroup.Label</option>
                                        }
                                    </select>
                                    <input class="form-control form-control-sm code-edit-input wide-code" name="BranchCode" value="@branch.BranchCode" maxlength="24" />
                                    <input class="form-control form-control-sm" name="Name" value="@branch.Name" maxlength="180" />
                                    <button class="btn btn-sm btn-outline-primary" type="submit" data-confirm="Şubeyi güncellemek istediğinize emin misiniz?">Güncelle</button>
                                </form>
                                <form asp-action="DeleteBranch" method="post" class="button-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="Id" value="@branch.Id" />
                                    <button class="btn btn-sm btn-outline-danger" type="submit" data-confirm="Şubeyi silmek istediğinize emin misiniz? Puan kayıtları da silinir.">Sil</button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            </article>
        }
    </div>
</section>
