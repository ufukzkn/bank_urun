@using BankUrun.Web.Models
@model BankUrun.Web.ViewModels.DashboardSnapshotViewModel
@functions {
    private static string Calculation(MainProductCalculationType type) => type == MainProductCalculationType.Average ? "Ortalamalı" : "Kümülatif";
    private static string Text(decimal? value) => value.HasValue ? value.Value.ToString("N2") : "Veri bekleniyor";
    private static string Inv(decimal? value, decimal fallback = -1) => (value ?? fallback).ToString(System.Globalization.CultureInfo.InvariantCulture);
    private static string Tone(decimal? ratio) => ratio switch { >= 90 => "performance-tone-excellent", >= 80 => "performance-tone-good", >= 70 => "performance-tone-watch", not null => "performance-tone-low", _ => "performance-tone-pending" };
}

<div class="performance-mode-content is-entering" data-dashboard-mode="@Model.Mode">
@if (Model.Mode == PerformanceMode.Branch)
{
    <section class="surface-panel table-panel compact-list-panel performance-search-panel" data-list="performanceBranches">
        <div class="panel-heading dashboard-search-heading"><div><span class="dashboard-context-code">@Model.PeriodScopeLabel</span><h2>Şube performansı</h2><p>Resmî sıra aynı grup, yıl ve dönemdeki toplam puanlara göre hesaplanır.</p></div><span class="result-count-chip">@Model.Branches.Count sonuç</span></div>
        <div class="table-toolbar performance-search-toolbar"><label class="toolbar-search"><span>Şube ara</span><input class="form-control" type="search" data-list-filter="search" placeholder="Grup, şube kodu veya adı" /></label><label><span>Sayfa boyutu</span><select class="form-select" data-list-page-size><option value="10">10</option><option value="25" selected>25</option><option value="50">50</option></select></label></div>
        <div class="table-responsive performance-table-scroll"><table class="table compact-table performance-search-table"><thead><tr>
            <th><button class="sort-button" type="button" data-list-sort="year">Yıl <span></span></button></th><th><button class="sort-button" type="button" data-list-sort="term">Dönem <span></span></button></th><th><button class="sort-button" type="button" data-list-sort="group">Grup <span></span></button></th><th><button class="sort-button" type="button" data-list-sort="branch">Şube <span></span></button></th><th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="criterion">Kriter <span></span></button></th><th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="hgo">HGO <span></span></button></th><th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="total">Toplam <span></span></button></th><th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="ratio">Başarı <span></span></button></th><th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="rank" title="Aynı grup, yıl ve dönemdeki şubelerin toplam puana göre yoğun sırası.">Grup sırası <span></span></button></th><th class="text-end">İşlem</th>
        </tr></thead><tbody>
        @foreach (var row in Model.Branches)
        {
            var detailId = $"branch-performance-{row.Year}-{row.Term}-{row.BranchId}";
            <tr class="list-row @Tone(row.SuccessPercent)" data-detail-id="@detailId" data-search="@($"{row.GroupNo} {row.GroupName} {row.BranchCode} {row.BranchName}".ToUpperInvariant())" data-year="@row.Year" data-term="@row.Term" data-group="@($"{row.GroupNo} {row.GroupName}")" data-branch="@($"{row.BranchCode} {row.BranchName}")" data-criterion="@Inv(row.CriterionScore)" data-hgo="@Inv(row.HgoScore)" data-total="@Inv(row.TotalScore)" data-ratio="@Inv(row.SuccessPercent)" data-rank="@(row.Rank ?? int.MaxValue)">
                <td class="numeric-cell">@row.Year</td><td class="numeric-cell">@row.Term</td><td><strong>@row.GroupNo</strong><small>@row.GroupName</small></td><td><strong>@row.BranchCode</strong><small>@row.BranchName</small></td><td class="text-end numeric-cell">@row.CriterionScore.ToString("N2")</td><td class="text-end numeric-cell">@Text(row.HgoScore)</td><td class="text-end numeric-cell"><strong>@Text(row.TotalScore)</strong></td><td class="text-end numeric-cell"><span class="performance-ratio-chip">@(row.SuccessPercent.HasValue ? $"%{row.SuccessPercent:N2}" : "—")</span></td><td class="text-end numeric-cell">@(row.Rank.HasValue ? $"{row.Rank} / {row.RankCandidateCount}" : "—")</td><td class="text-end"><button class="btn btn-sm btn-outline-primary detail-button" type="button" data-bs-toggle="collapse" data-bs-target="#@detailId">Detay</button></td>
            </tr>
            <tr class="list-detail-row" data-detail-for="@detailId"><td colspan="10"><div class="collapse" id="@detailId"><div class="branch-inline-detail"><div><strong>@row.CompleteProductCount / @row.ProductCount ana ürün tamamlandı</strong><span>@(row.HasCompletePeriodData ? "Dönem batch'i tamamlandı." : "Eksik hedef veya alt ürün batch'i bulunuyor.")</span></div><button class="btn btn-sm btn-primary" type="button" data-inspect-branch data-group-id="@row.GroupId" data-branch-id="@row.BranchId" data-year="@row.Year" data-term="@row.Term" data-branch-label="@($"{row.BranchCode} - {row.BranchName}")">Şubeyi incele</button></div></div></td></tr>
        }
        <tr class="empty-row @(Model.Branches.Count == 0 ? "" : "d-none")" data-list-empty><td colspan="10" class="empty-cell">Filtreye uygun şube bulunamadı.</td></tr>
        </tbody></table></div>@await Html.PartialAsync("_ListPager")
    </section>
}
else if (Model.Mode == PerformanceMode.BranchProduct)
{
    @if (Model.HasSelectedBranch && Model.Year.HasValue && Model.Term.HasValue)
    {
        <div class="dashboard-snapshot-heading"><div><span class="dashboard-context-code">@Model.GroupNo · @Model.PeriodScopeLabel</span><h2>@Model.BranchCode · @Model.BranchName</h2><p>Şubenin ana ürün sonuçları bağlı portföylerinden türetilir.</p></div><span class="dashboard-period-chip @(Model.HasCompletePeriodData ? "is-complete" : "is-waiting")">@(Model.HasCompletePeriodData ? "Dönem tamamlandı" : "Veri bekleniyor")</span></div>
        <div class="dashboard-kpi-grid branch-summary-grid"><article class="dashboard-kpi-card"><span>Toplam kriter</span><strong>@Model.AssignedScore.ToString("N2")</strong></article><article class="dashboard-kpi-card"><span>Toplam HGO</span><strong>@Text(Model.EarnedScore)</strong></article><article class="dashboard-kpi-card"><span>Toplam puan</span><strong>@Text(Model.EarnedScore)</strong></article><article class="dashboard-kpi-card"><span>Grup sırası</span><strong>@(Model.BranchRank.HasValue ? $"{Model.BranchRank} / {Model.RankedBranchCount}" : "—")</strong></article></div>
    }
    <section class="surface-panel table-panel compact-list-panel performance-search-panel" data-list="performanceBranchProducts">
        <div class="panel-heading dashboard-search-heading"><div><span class="dashboard-context-code">@Model.PeriodScopeLabel</span><h2>Şube–ürün performansı</h2><p>Sıra aynı grup, dönem ve ana üründeki şubeler arasında hesaplanır.</p></div><span class="result-count-chip">@Model.BranchProducts.Count sonuç</span></div>
        <div class="table-toolbar performance-search-toolbar"><label class="toolbar-search"><span>Şube veya ürün ara</span><input class="form-control" type="search" data-list-filter="search" placeholder="Kod, şube veya ürün adı" /></label><label><span>Sayfa boyutu</span><select class="form-select" data-list-page-size><option value="10">10</option><option value="25" selected>25</option><option value="50">50</option></select></label></div>
        <div class="table-responsive performance-table-scroll"><table class="table compact-table performance-search-table"><thead><tr>
            <th><button class="sort-button" type="button" data-list-sort="year">Yıl <span></span></button></th><th><button class="sort-button" type="button" data-list-sort="term">Dönem <span></span></button></th><th><button class="sort-button" type="button" data-list-sort="group">Grup <span></span></button></th><th><button class="sort-button" type="button" data-list-sort="branch">Şube <span></span></button></th><th><button class="sort-button" type="button" data-list-sort="product">Ana ürün <span></span></button></th><th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="criterion">Kriter <span></span></button></th><th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="target">Hedef <span></span></button></th><th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="actual">Gerçekleşme <span></span></button></th><th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="ratio">H/G <span></span></button></th><th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="hgo">HGO <span></span></button></th><th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="total">Toplam <span></span></button></th><th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="rank" title="Aynı grup, yıl, dönem ve ana üründeki şubelerin toplam puana göre yoğun sırası; organizasyon grup tipi değildir.">Segment sırası <span></span></button></th><th class="text-end">İşlem</th>
        </tr></thead><tbody>
        @foreach (var row in Model.BranchProducts)
        {
            var detailId = $"branch-product-{row.Year}-{row.Term}-{row.BranchId}-{row.MainProductInstanceId}";
            <tr class="list-row @Tone(row.HgRatioPercent)" data-detail-id="@detailId" data-search="@($"{row.GroupNo} {row.GroupName} {row.BranchCode} {row.BranchName} {row.ProductCode} {row.ProductName}".ToUpperInvariant())" data-year="@row.Year" data-term="@row.Term" data-group="@($"{row.GroupNo} {row.GroupName}")" data-branch="@($"{row.BranchCode} {row.BranchName}")" data-product="@($"{row.ProductCode} {row.ProductName}")" data-criterion="@Inv(row.CriterionScore)" data-target="@Inv(row.TargetValue)" data-actual="@Inv(row.ActualValue)" data-ratio="@Inv(row.HgRatioPercent)" data-hgo="@Inv(row.HgoScore)" data-total="@Inv(row.TotalScore)" data-rank="@(row.SegmentRank ?? int.MaxValue)">
                <td class="numeric-cell">@row.Year</td><td class="numeric-cell">@row.Term</td><td><strong>@row.GroupNo</strong><small>@row.GroupName</small></td><td><strong>@row.BranchCode</strong><small>@row.BranchName</small></td><td><strong>@row.ProductCode</strong><small>@row.ProductName</small><span class="calculation-badge">@Calculation(row.CalculationType)</span>@if (!row.HasParameterConfiguration) { <span class="data-waiting-badge">Parametre bekleniyor</span> } else if (!row.HasSubProductConfiguration) { <span class="data-waiting-badge">Alt ürün bağlantısı yok</span> } else if (!row.HasCompleteTargetData) { <span class="data-waiting-badge">Hedef bekleniyor</span> } else if (!row.HasCompleteBatchData) { <span class="data-waiting-badge">Veri bekleniyor</span> }</td><td class="text-end numeric-cell">@row.CriterionScore.ToString("N2")</td><td class="text-end numeric-cell">@row.TargetValue.ToString("N2")</td><td class="text-end numeric-cell">@Text(row.ActualValue)</td><td class="text-end numeric-cell"><span class="performance-ratio-chip">@(row.HgRatioPercent.HasValue ? $"%{row.HgRatioPercent:N2}" : "—")</span></td><td class="text-end numeric-cell">@Text(row.HgoScore)</td><td class="text-end numeric-cell"><strong>@Text(row.TotalScore)</strong></td><td class="text-end numeric-cell">@(row.SegmentRank.HasValue ? $"{row.SegmentRank} / {row.SegmentRankCandidateCount}" : "—")</td><td class="text-end"><button class="btn btn-sm btn-outline-primary detail-button" type="button" data-bs-toggle="collapse" data-bs-target="#@detailId" data-monthly-detail="branch" data-branch-id="@row.BranchId" data-product-id="@row.MainProductInstanceId">Detay</button></td>
            </tr><tr class="list-detail-row" data-detail-for="@detailId"><td colspan="13"><div class="collapse" id="@detailId"><div class="performance-lazy-detail" data-monthly-detail-target><div class="inline-loading-state">Aylık detay yalnız bu alan açıldığında yüklenir.</div></div></div></td></tr>
        }
        <tr class="empty-row @(Model.BranchProducts.Count == 0 ? "" : "d-none")" data-list-empty><td colspan="13" class="empty-cell">Filtreye uygun şube–ürün sonucu bulunamadı.</td></tr>
        </tbody></table></div>@await Html.PartialAsync("_ListPager")
    </section>
}
else if (Model.Mode == PerformanceMode.MainProduct)
{
    <section class="surface-panel table-panel compact-list-panel performance-search-panel" data-list="performanceMainProducts">
        <div class="panel-heading dashboard-search-heading"><div><span class="dashboard-context-code">@Model.PeriodScopeLabel · @Model.GroupName</span><h2>Ana ürün performansı</h2><p>Ana ürünler kapsamdaki şubelerin portföy sonuçlarından oluşturulur.</p></div><span class="result-count-chip">@Model.MainProducts.Count sonuç</span></div>
        <div class="table-toolbar performance-search-toolbar"><label class="toolbar-search"><span>Ana ürün ara</span><input class="form-control" type="search" data-list-filter="search" placeholder="Ürün kodu veya adı" /></label><label><span>Sayfa boyutu</span><select class="form-select" data-list-page-size><option value="5">5</option><option value="10" selected>10</option><option value="25">25</option></select></label></div>
        <div class="table-responsive performance-table-scroll"><table class="table compact-table performance-search-table"><thead><tr>
            <th><button class="sort-button" type="button" data-list-sort="year">Yıl <span></span></button></th><th><button class="sort-button" type="button" data-list-sort="term">Dönem <span></span></button></th><th><button class="sort-button" type="button" data-list-sort="product">Ana ürün <span></span></button></th><th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="subCount">Alt ürün <span></span></button></th><th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="branchCount">Şube <span></span></button></th><th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="criterion">Kriter <span></span></button></th><th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="target">Hedef <span></span></button></th><th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="actual">Gerçekleşme <span></span></button></th><th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="ratio">H/G <span></span></button></th><th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="hgo">HGO <span></span></button></th><th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="total">Toplam <span></span></button></th><th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="rank" title="Seçili grup kapsamındaki ana ürünlerin aynı yıl ve dönemde toplam puana göre yoğun sırası.">Ana ürün sırası <span></span></button></th><th class="text-end">İşlem</th>
        </tr></thead><tbody>
        @foreach (var row in Model.MainProducts)
        {
            var detailId = $"main-product-{row.Year}-{row.Term}-{row.MainProductInstanceId}";
            <tr class="list-row @Tone(row.HgRatioPercent)" data-detail-id="@detailId" data-search="@($"{row.ProductCode} {row.ProductName}".ToUpperInvariant())" data-year="@row.Year" data-term="@row.Term" data-product="@($"{row.ProductCode} {row.ProductName}")" data-sub-count="@row.SubProductCount" data-branch-count="@row.BranchCount" data-criterion="@Inv(row.CriterionScore)" data-target="@Inv(row.TargetValue)" data-actual="@Inv(row.ActualValue)" data-ratio="@Inv(row.HgRatioPercent)" data-hgo="@Inv(row.HgoScore)" data-total="@Inv(row.TotalScore)" data-rank="@(row.Rank ?? int.MaxValue)">
                <td class="numeric-cell">@row.Year</td><td class="numeric-cell">@row.Term</td><td><strong>@row.ProductCode</strong><small>@row.ProductName</small>@if (!row.HasParameterConfiguration) { <span class="data-waiting-badge">Parametre bekleniyor</span> } else if (!row.HasSubProductConfiguration) { <span class="data-waiting-badge">Alt ürün bağlantısı yok</span> } else if (!row.HasCompleteTargetData) { <span class="data-waiting-badge">Hedef bekleniyor</span> } else if (!row.HasCompleteBatchData) { <span class="data-waiting-badge">Veri bekleniyor</span> }</td><td class="text-end numeric-cell">@row.SubProductCount</td><td class="text-end numeric-cell">@row.BranchCount</td><td class="text-end numeric-cell">@row.CriterionScore.ToString("N2")</td><td class="text-end numeric-cell">@row.TargetValue.ToString("N2")</td><td class="text-end numeric-cell">@Text(row.ActualValue)</td><td class="text-end numeric-cell"><span class="performance-ratio-chip">@(row.HgRatioPercent.HasValue ? $"%{row.HgRatioPercent:N2}" : "—")</span></td><td class="text-end numeric-cell">@Text(row.HgoScore)</td><td class="text-end numeric-cell"><strong>@Text(row.TotalScore)</strong></td><td class="text-end numeric-cell">@(row.Rank.HasValue ? $"{row.Rank} / {row.RankCandidateCount}" : "—")</td><td class="text-end"><button class="btn btn-sm btn-outline-primary detail-button" type="button" data-bs-toggle="collapse" data-bs-target="#@detailId" data-monthly-detail="main" data-product-id="@row.MainProductInstanceId">Detay</button></td>
            </tr><tr class="list-detail-row" data-detail-for="@detailId"><td colspan="13"><div class="collapse" id="@detailId"><div class="performance-lazy-detail" data-monthly-detail-target><div class="inline-loading-state">Aylık genel toplam yalnız bu alan açıldığında yüklenir.</div></div></div></td></tr>
        }
        <tr class="empty-row @(Model.MainProducts.Count == 0 ? "" : "d-none")" data-list-empty><td colspan="13" class="empty-cell">Filtreye uygun ana ürün sonucu bulunamadı.</td></tr>
        </tbody></table></div>@await Html.PartialAsync("_ListPager")
    </section>
}
else
{
    <section class="surface-panel table-panel compact-list-panel performance-search-panel" data-list="performancePortfolios">
        <div class="panel-heading dashboard-search-heading"><div><span class="dashboard-context-code">@Model.PeriodScopeLabel · @Model.GroupName</span><h2>Portföy performansı</h2><p>Resmî sıra aynı grup ve ürün gamında; şube içi sıra başarı oranına göre hesaplanır.</p></div><span class="result-count-chip">@Model.Portfolios.Count sonuç</span></div>
        <div class="table-toolbar performance-search-toolbar"><label class="toolbar-search"><span>Portföy ara</span><input class="form-control" type="search" data-list-filter="search" placeholder="Şube, portföy, tip veya ürün gamı" /></label><label><span>Sayfa boyutu</span><select class="form-select" data-list-page-size><option value="10">10</option><option value="25" selected>25</option><option value="50">50</option></select></label></div>
        <div class="table-responsive performance-table-scroll"><table class="table compact-table performance-search-table"><thead><tr>
            <th><button class="sort-button" type="button" data-list-sort="year">Yıl <span></span></button></th><th><button class="sort-button" type="button" data-list-sort="term">Dönem <span></span></button></th><th><button class="sort-button" type="button" data-list-sort="group">Grup <span></span></button></th><th><button class="sort-button" type="button" data-list-sort="branch">Şube <span></span></button></th><th><button class="sort-button" type="button" data-list-sort="portfolio">Portföy <span></span></button></th><th><button class="sort-button" type="button" data-list-sort="type">Tip <span></span></button></th><th><button class="sort-button" type="button" data-list-sort="gamut">Ürün gamı <span></span></button></th><th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="criterion">Kriter <span></span></button></th><th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="hgo">HGO <span></span></button></th><th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="total">Toplam <span></span></button></th><th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="ratio">Başarı <span></span></button></th><th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="officialRank" title="Aynı grup, ürün gamı, yıl ve dönemde toplam puana göre resmî yoğun sıra.">Grup–gam sırası <span></span></button></th><th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="branchRank" title="Aynı şube, yıl ve dönemde başarı oranına göre yoğun sıra.">Şube içi sıra <span></span></button></th><th class="text-end">İşlem</th>
        </tr></thead><tbody>
        @foreach (var row in Model.Portfolios)
        {
            var detailId = $"portfolio-{row.Year}-{row.Term}-{row.PortfolioId}";
            <tr class="list-row @Tone(row.SuccessPercent)" data-detail-id="@detailId" data-search="@($"{row.GroupNo} {row.GroupName} {row.BranchCode} {row.BranchName} {row.PortfolioCode} {row.PortfolioName} {row.PortfolioTypeCode} {row.PortfolioTypeName} {row.ProductGamutCode} {row.ProductGamutName}".ToUpperInvariant())" data-year="@row.Year" data-term="@row.Term" data-group="@($"{row.GroupNo} {row.GroupName}")" data-branch="@($"{row.BranchCode} {row.BranchName}")" data-portfolio="@($"{row.PortfolioCode} {row.PortfolioName}")" data-type="@($"{row.PortfolioTypeCode} {row.PortfolioTypeName}")" data-gamut="@($"{row.ProductGamutCode} {row.ProductGamutName}")" data-criterion="@Inv(row.CriterionScore)" data-hgo="@Inv(row.HgoScore)" data-total="@Inv(row.TotalScore)" data-ratio="@Inv(row.SuccessPercent)" data-official-rank="@(row.OfficialRank ?? int.MaxValue)" data-branch-rank="@(row.BranchRank ?? int.MaxValue)">
                <td class="numeric-cell">@row.Year</td><td class="numeric-cell">@row.Term</td><td><strong>@row.GroupNo</strong><small>@row.GroupName</small></td><td><strong>@row.BranchCode</strong><small>@row.BranchName</small></td><td><strong>@row.PortfolioCode</strong><small>@row.PortfolioName</small></td><td><span class="calculation-badge">@row.PortfolioTypeCode</span><small>@row.PortfolioTypeName</small></td><td><strong>@row.ProductGamutCode</strong><small>@row.ProductGamutName</small></td><td class="text-end numeric-cell">@row.CriterionScore.ToString("N2")</td><td class="text-end numeric-cell">@Text(row.HgoScore)</td><td class="text-end numeric-cell"><strong>@Text(row.TotalScore)</strong></td><td class="text-end numeric-cell"><span class="performance-ratio-chip">@(row.SuccessPercent.HasValue ? $"%{row.SuccessPercent:N2}" : "—")</span></td><td class="text-end numeric-cell">@(row.OfficialRank.HasValue ? $"{row.OfficialRank} / {row.OfficialRankCandidateCount}" : "—")</td><td class="text-end numeric-cell">@(row.BranchRank.HasValue ? $"{row.BranchRank} / {row.BranchRankCandidateCount}" : "—")</td><td class="text-end"><button class="btn btn-sm btn-outline-primary detail-button" type="button" data-bs-toggle="collapse" data-bs-target="#@detailId" data-monthly-detail="portfolio" data-portfolio-id="@row.PortfolioId" data-year="@row.Year" data-term="@row.Term">Detay</button></td>
            </tr><tr class="list-detail-row" data-detail-for="@detailId"><td colspan="14"><div class="collapse" id="@detailId"><div class="performance-lazy-detail" data-monthly-detail-target><div class="inline-loading-state">Portföy ürün ve aylık detayı yalnız bu alan açıldığında yüklenir.</div></div></div></td></tr>
        }
        <tr class="empty-row @(Model.Portfolios.Count == 0 ? "" : "d-none")" data-list-empty><td colspan="14" class="empty-cell">Filtreye uygun portföy sonucu bulunamadı.</td></tr>
        </tbody></table></div>@await Html.PartialAsync("_ListPager")
    </section>
}
</div>
