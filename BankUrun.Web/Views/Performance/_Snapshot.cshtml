@using BankUrun.Web.Models
@model BankUrun.Web.ViewModels.DashboardSnapshotViewModel

@{
    var listName = Model.Mode switch
    {
        PerformanceMode.Branch => "performanceBranches",
        PerformanceMode.BranchProduct => "performanceBranchProducts",
        PerformanceMode.MainProduct => "performanceMainProducts",
        _ => "performancePortfolios"
    };
    var resultLabel = Model.Mode switch
    {
        PerformanceMode.Branch => "şube",
        PerformanceMode.BranchProduct => "sonuç",
        PerformanceMode.MainProduct => "ana ürün",
        _ => "portföy"
    };
}

<div class="performance-mode-content is-entering" data-dashboard-mode="@Model.Mode">
    @if (Model.Mode == PerformanceMode.BranchProduct && Model.HasSelectedBranch && Model.Year.HasValue && Model.Term.HasValue)
    {
        <div class="dashboard-snapshot-heading">
            <div>
                <span class="dashboard-context-code">@Model.GroupNo · @Model.PeriodScopeLabel</span>
                <h2>@Model.BranchCode · @Model.BranchName</h2>
                <p>Şubenin ana ürün sonuçları bağlı portföylerinden türetilir.</p>
            </div>
            <span class="dashboard-period-chip @(Model.HasCompletePeriodData ? "is-complete" : "is-waiting")">
                @(Model.HasCompletePeriodData ? "Dönem tamamlandı" : "Veri bekleniyor")
            </span>
        </div>
        <div class="dashboard-kpi-grid branch-summary-grid">
            <article class="dashboard-kpi-card"><span>Toplam kriter</span><strong>@Model.AssignedScore.ToString("N2")</strong></article>
            <article class="dashboard-kpi-card"><span>Toplam HGO</span><strong>@(Model.EarnedScore.HasValue ? Model.EarnedScore.Value.ToString("N2") : "Veri bekleniyor")</strong></article>
            <article class="dashboard-kpi-card"><span>Toplam puan</span><strong>@(Model.EarnedScore.HasValue ? Model.EarnedScore.Value.ToString("N2") : "Veri bekleniyor")</strong></article>
            <article class="dashboard-kpi-card"><span>Grup sırası</span><strong>@(Model.BranchRank.HasValue ? $"{Model.BranchRank} / {Model.RankedBranchCount}" : "—")</strong></article>
        </div>
    }

    <section class="surface-panel table-panel compact-list-panel performance-search-panel"
             data-list="@listName"
             data-list-page="@Model.Page"
             data-list-total-pages="@Model.TotalPages"
             data-list-total-count="@Model.TotalCount"
             aria-busy="false">
        <div class="panel-heading dashboard-search-heading">
            @if (Model.Mode == PerformanceMode.Branch)
            {
                <div><span class="dashboard-context-code">@Model.PeriodScopeLabel</span><h2>Şube performansı</h2><p>Resmî sıra aynı grup, yıl ve dönemdeki toplam puanlara göre hesaplanır.</p></div>
            }
            else if (Model.Mode == PerformanceMode.BranchProduct)
            {
                <div><span class="dashboard-context-code">@Model.PeriodScopeLabel</span><h2>Şube–ürün performansı</h2><p>Sıra aynı grup, dönem ve ana üründeki şubeler arasında hesaplanır.</p></div>
            }
            else if (Model.Mode == PerformanceMode.MainProduct)
            {
                <div><span class="dashboard-context-code">@Model.PeriodScopeLabel · @Model.GroupName</span><h2>Ana ürün performansı</h2><p>Ana ürünler kapsamdaki şubelerin portföy sonuçlarından oluşturulur.</p></div>
            }
            else
            {
                <div><span class="dashboard-context-code">@Model.PeriodScopeLabel · @Model.GroupName</span><h2>Portföy performansı</h2><p>Resmî sıra aynı grup ve ürün gamında; şube içi sıra başarı oranına göre hesaplanır.</p></div>
            }
            <span class="result-count-chip" data-performance-result-count>@Model.TotalCount sonuç</span>
        </div>

        <div class="table-toolbar performance-search-toolbar">
            <label class="toolbar-search">
                <span>@(Model.Mode == PerformanceMode.Branch ? "Şube ara" : Model.Mode == PerformanceMode.BranchProduct ? "Şube veya ürün ara" : Model.Mode == PerformanceMode.MainProduct ? "Ana ürün ara" : "Portföy ara")</span>
                <input class="form-control" type="search" data-list-filter="search"
                       placeholder="@(Model.Mode == PerformanceMode.Branch ? "Grup, şube kodu veya adı" : Model.Mode == PerformanceMode.BranchProduct ? "Kod, şube veya ürün adı" : Model.Mode == PerformanceMode.MainProduct ? "Ürün kodu veya adı" : "Şube, portföy, tip veya ürün gamı")" />
            </label>
            <label>
                <span>Sayfa boyutu</span>
                <select class="form-select" data-list-page-size>
                    @if (Model.Mode == PerformanceMode.MainProduct)
                    {
                        <option value="10" selected="@(Model.PageSize == 10)">10</option>
                        <option value="25" selected="@(Model.PageSize == 25)">25</option>
                        <option value="50" selected="@(Model.PageSize == 50)">50</option>
                    }
                    else
                    {
                        <option value="10" selected="@(Model.PageSize == 10)">10</option>
                        <option value="25" selected="@(Model.PageSize == 25)">25</option>
                        <option value="50" selected="@(Model.PageSize == 50)">50</option>
                    }
                </select>
            </label>
        </div>

        <div class="table-responsive performance-table-scroll">
            <table class="table compact-table performance-search-table">
                <thead>
                @if (Model.Mode == PerformanceMode.Branch)
                {
                    <tr>
                        <th><button class="sort-button" type="button" data-list-sort="year">Yıl <span></span></button></th>
                        <th><button class="sort-button" type="button" data-list-sort="term">Dönem <span></span></button></th>
                        <th><button class="sort-button" type="button" data-list-sort="group">Grup <span></span></button></th>
                        <th><button class="sort-button" type="button" data-list-sort="branch">Şube <span></span></button></th>
                        <th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="criterion">Kriter <span></span></button></th>
                        <th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="hgo">HGO <span></span></button></th>
                        <th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="total">Toplam <span></span></button></th>
                        <th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="ratio">Başarı <span></span></button></th>
                        <th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="rank" title="Aynı grup, yıl ve dönemdeki şubelerin toplam puana göre yoğun sırası.">Grup sırası <span></span></button></th>
                        <th class="text-end">İşlem</th>
                    </tr>
                }
                else if (Model.Mode == PerformanceMode.BranchProduct)
                {
                    <tr>
                        <th><button class="sort-button" type="button" data-list-sort="year">Yıl <span></span></button></th>
                        <th><button class="sort-button" type="button" data-list-sort="term">Dönem <span></span></button></th>
                        <th><button class="sort-button" type="button" data-list-sort="group">Grup <span></span></button></th>
                        <th><button class="sort-button" type="button" data-list-sort="branch">Şube <span></span></button></th>
                        <th><button class="sort-button" type="button" data-list-sort="product">Ana ürün <span></span></button></th>
                        <th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="criterion">Kriter <span></span></button></th>
                        <th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="target">Hedef <span></span></button></th>
                        <th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="actual">Gerçekleşme <span></span></button></th>
                        <th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="ratio">H/G <span></span></button></th>
                        <th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="hgo">HGO <span></span></button></th>
                        <th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="total">Toplam <span></span></button></th>
                        <th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="rank" title="Aynı grup, yıl, dönem ve ana üründeki şubelerin toplam puana göre yoğun sırası; organizasyon grup tipi değildir.">Segment sırası <span></span></button></th>
                        <th class="text-end">İşlem</th>
                    </tr>
                }
                else if (Model.Mode == PerformanceMode.MainProduct)
                {
                    <tr>
                        <th><button class="sort-button" type="button" data-list-sort="year">Yıl <span></span></button></th>
                        <th><button class="sort-button" type="button" data-list-sort="term">Dönem <span></span></button></th>
                        <th><button class="sort-button" type="button" data-list-sort="product">Ana ürün <span></span></button></th>
                        <th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="subCount">Alt ürün <span></span></button></th>
                        <th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="branchCount">Şube <span></span></button></th>
                        <th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="criterion">Kriter <span></span></button></th>
                        <th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="target">Hedef <span></span></button></th>
                        <th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="actual">Gerçekleşme <span></span></button></th>
                        <th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="ratio">H/G <span></span></button></th>
                        <th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="hgo">HGO <span></span></button></th>
                        <th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="total">Toplam <span></span></button></th>
                        <th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="rank" title="Seçili grup kapsamındaki ana ürünlerin aynı yıl ve dönemde toplam puana göre yoğun sırası.">Ana ürün sırası <span></span></button></th>
                        <th class="text-end">İşlem</th>
                    </tr>
                }
                else
                {
                    <tr>
                        <th><button class="sort-button" type="button" data-list-sort="year">Yıl <span></span></button></th>
                        <th><button class="sort-button" type="button" data-list-sort="term">Dönem <span></span></button></th>
                        <th><button class="sort-button" type="button" data-list-sort="group">Grup <span></span></button></th>
                        <th><button class="sort-button" type="button" data-list-sort="branch">Şube <span></span></button></th>
                        <th><button class="sort-button" type="button" data-list-sort="portfolio">Portföy <span></span></button></th>
                        <th><button class="sort-button" type="button" data-list-sort="type">Tip <span></span></button></th>
                        <th><button class="sort-button" type="button" data-list-sort="gamut">Ürün gamı <span></span></button></th>
                        <th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="criterion">Kriter <span></span></button></th>
                        <th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="hgo">HGO <span></span></button></th>
                        <th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="total">Toplam <span></span></button></th>
                        <th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="ratio">Başarı <span></span></button></th>
                        <th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="officialRank" title="Aynı grup, ürün gamı, yıl ve dönemde toplam puana göre resmî yoğun sıra.">Grup–gam sırası <span></span></button></th>
                        <th class="text-end"><button class="sort-button justify-content-end" type="button" data-list-sort="branchRank" title="Aynı şube, yıl ve dönemde başarı oranına göre yoğun sıra.">Şube içi sıra <span></span></button></th>
                        <th class="text-end">İşlem</th>
                    </tr>
                }
                </thead>
                <tbody data-remote-list-body>
                    @await Html.PartialAsync("_PerformanceRows", Model)
                </tbody>
            </table>
        </div>
        @await Html.PartialAsync("_ListPager")
    </section>
</div>
