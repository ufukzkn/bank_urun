@model BankUrun.Web.ViewModels.DashboardMonthlyDetailViewModel
@functions {
    private static string Calculation(BankUrun.Web.Models.MainProductCalculationType type) =>
        type == BankUrun.Web.Models.MainProductCalculationType.Average ? "Ortalamalı" : "Kümülatif";
}
<div class="performance-product-detail">
    <div class="performance-detail-heading">
        <div>
            <h3>@Model.Title</h3>
            <p>@Model.Subtitle · @Calculation(Model.CalculationType)</p>
        </div>
    </div>
    <div class="performance-detail-actions" role="group" aria-label="Detay bölümleri">
        <button class="btn btn-sm btn-outline-primary" type="button"
                data-lazy-performance-section="months"
                data-lazy-performance-url="@ViewData["MonthsUrl"]"
                aria-expanded="false">
            Aylık gidişatı göster
        </button>
        <button class="btn btn-sm btn-outline-primary" type="button"
                data-lazy-performance-section="contributions"
                data-lazy-performance-url="@ViewData["ContributionsUrl"]"
                aria-expanded="false">
            Alt ürün katkılarını göster
        </button>
    </div>
    <div class="performance-detail-section-target" data-lazy-performance-target="months" hidden></div>
    <div class="performance-detail-section-target" data-lazy-performance-target="contributions" hidden></div>
</div>
