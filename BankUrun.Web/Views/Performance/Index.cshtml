@model BankUrun.Web.ViewModels.DashboardIndexViewModel

@{
    ViewData["Title"] = "Performans";
    var selectedBranch = Model.Branches.FirstOrDefault(branch => branch.Id == Model.SelectedBranchId);
}

<section class="page-title dashboard-page-title">
    <div>
        <h1>Performans</h1>
        <p>Şube ve ana ürün bazında dönemsel performans görünümü.</p>
    </div>
    <span class="batch-date">Batch tarihi <strong>@Model.BatchDate.ToString("dd.MM.yyyy")</strong></span>
</section>

<section class="dashboard-workspace"
         data-dashboard
         data-snapshot-url="@Url.Action("Snapshot", "Performance")">
    <div class="surface-panel dashboard-context-panel">
        <div class="dashboard-context-heading-row">
            <div class="dashboard-context-copy">
                <h2>Performans bağlamı</h2>
                <p>Dönem sonuçlarını şube veya ana ürün kırılımında inceleyin.</p>
            </div>
        </div>
        <div class="dashboard-context-grid performance-context-grid">
            <label>
                <span>Grup</span>
                <select class="form-select" data-dashboard-filter="groupId">
                    @foreach (var group in Model.Groups)
                    {
                        <option value="@group.Id" selected="@(group.Id == Model.SelectedGroupId)">@group.GroupNo - @group.Name</option>
                    }
                </select>
            </label>
            <label class="dashboard-branch-field">
                <span>Şube</span>
                <div class="combo generic-combo">
                    <input class="form-control" type="search" autocomplete="off" value="@selectedBranch?.Label" placeholder="Kod veya şube adı ara" data-combo-input />
                    <input type="hidden" value="@Model.SelectedBranchId" data-combo-value data-dashboard-filter="branchId" />
                    <div class="combo-menu dashboard-branch-menu">
                        @foreach (var branch in Model.Branches)
                        {
                            <button class="combo-option"
                                    type="button"
                                    data-combo-option
                                    data-id="@branch.Id"
                                    data-label="@branch.Label"
                                    data-group-id="@branch.GroupId">
                                <strong>@branch.BranchCode</strong>
                                <span>@branch.Name</span>
                                <small>@branch.GroupSegment</small>
                                <small class="combo-option-description">@branch.GroupNo - @branch.GroupName</small>
                            </button>
                        }
                        <div class="combo-empty">Eşleşen şube bulunamadı.</div>
                    </div>
                </div>
            </label>
            <label>
                <span>Yıl</span>
                <select class="form-select" data-dashboard-filter="year">
                    @foreach (var year in Model.Years)
                    {
                        <option value="@year" selected="@(year == Model.SelectedYear)">@year</option>
                    }
                </select>
            </label>
            <label>
                <span>Dönem</span>
                <select class="form-select" data-dashboard-filter="term">
                    <option value="1" selected="@(Model.SelectedTerm == 1)">1. Dönem</option>
                    <option value="2" selected="@(Model.SelectedTerm == 2)">2. Dönem</option>
                </select>
            </label>
            <label class="dashboard-product-field">
                <span>Ana ürün</span>
                <div class="combo generic-combo">
                    <input class="form-control" type="search" autocomplete="off" placeholder="Tüm ana ürünler" data-combo-input />
                    <input type="hidden" value="" data-combo-value data-dashboard-filter="mainProductInstanceId" />
                    <div class="combo-menu dashboard-product-menu">
                        <button class="combo-option" type="button" data-combo-option data-id="" data-label="Tüm ana ürünler">
                            <strong>Tümü</strong><span>Tüm ana ürünleri göster</span>
                        </button>
                        @foreach (var product in Model.Products)
                        {
                            <button class="combo-option"
                                    type="button"
                                    data-combo-option
                                    data-id="@product.Id"
                                    data-label="@product.Label"
                                    data-year="@product.Year"
                                    data-term="@product.Term">
                                <strong>@product.Code</strong>
                                <span>@product.Name</span>
                                <small>@product.Year / @product.Term. Dönem</small>
                            </button>
                        }
                        <div class="combo-empty">Ana ürün bulunamadı.</div>
                    </div>
                </div>
            </label>
            <a class="btn btn-outline-primary dashboard-parameter-link" asp-controller="Parameters" asp-action="Index">Parametreleri yönet</a>
        </div>
    </div>

    <nav class="dashboard-view-picker" aria-label="Performans içeriği">
        <button class="is-active" type="button" data-dashboard-section-mode="branches" aria-pressed="true">
            Şube performansı
        </button>
        <button type="button" data-dashboard-section-mode="products" aria-pressed="false">
            Ana ürün performansı
        </button>
    </nav>

    <div data-dashboard-snapshot>
        @await Html.PartialAsync("_Snapshot", Model.Snapshot)
    </div>
</section>
